{
  "name": "hydromart",
  "version": "0.1.0",
  "private": true,
  "description": "Hydromart — digital platform for refillable drinking-water depot operations",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "services/*",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:validate": "npm run prisma:validate --workspaces --if-present",
    "db:migrate": "npm run prisma:migrate --workspaces --if-present",
    "db:migrate:prod": "bash scripts/migrate-prod.sh",
    "db:generate": "npm run prisma:generate --workspaces --if-present",
    "auth:dev": "npm run start:dev --workspace @hydromart/auth-service",
    "auth:migrate": "npm run prisma:migrate --workspace @hydromart/auth-service",
    "test:integration": "node test/integration/run.mjs",
    "db:seed": "node scripts/seed.mjs",
    "gen:vapid": "node scripts/gen-vapid.mjs"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}
