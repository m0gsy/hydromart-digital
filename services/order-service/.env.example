NODE_ENV=development
ORDER_SERVICE_PORT=3004
ORDER_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_order?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
# Base URL of the product-service used to resolve authoritative prices at checkout.
PRODUCT_SERVICE_URL=http://localhost:3003
DEPOT_SERVICE_URL=http://localhost:3007
# Flat delivery fee applied at checkout, in IDR (per-depot/zone pricing lands in M5).
ORDER_DELIVERY_FEE=5000
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
# Loyalty-service: awards points on order completion (BR-013).
LOYALTY_SERVICE_URL=http://localhost:3009
# Promo-service: validates/redeems vouchers at checkout (BR-015).
PROMO_SERVICE_URL=http://localhost:3010
# Referral-service: qualifies referrals on order completion (FR-092).
REFERRAL_SERVICE_URL=http://localhost:3011
# CRM-service: sends WhatsApp notifications on order lifecycle changes (FR-093/FR-094).
CRM_SERVICE_URL=http://localhost:3012
