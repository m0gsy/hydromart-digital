// Hydromart order-service data model (PRD Module 4, Cart → Checkout → Order).
// Owns the shopping cart and the order lifecycle. Prices and the delivery
// address are SNAPSHOTTED at checkout so historical orders never drift when the
// catalog or the customer's address book changes later.

generator client {
  provider = "prisma-client-js"
  // Service-local output so it never clobbers other services' @prisma/client.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("ORDER_DATABASE_URL")
}

// BR-012 order lifecycle. CANCELLED is reachable only before DRIVER_ASSIGNED
// (BR-006); the sequence is otherwise strictly forward.
enum OrderStatus {
  CREATED
  CONFIRMED
  PREPARING
  DRIVER_ASSIGNED
  PICKED_UP
  ON_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
}

/// A line in a customer's active cart. One row per (customer, product).
model CartItem {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @db.Uuid
  productId  String   @db.Uuid
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("cart_items")
}

/// A placed order. Money is stored in IDR with 2 decimals for consistency with
/// the catalog. Delivery address fields are a snapshot taken at checkout.
model Order {
  id          String      @id @default(uuid()) @db.Uuid
  orderNumber String      @unique
  customerId  String      @db.Uuid
  status      OrderStatus @default(CREATED)

  /// Fulfilling depot, resolved at checkout by delivery-address proximity
  /// (nearest active depot within its service radius). Null when the address
  /// has no coordinates or no depot covers it. Powers Top-Depot reporting (FR-098).
  depotId     String?     @db.Uuid

  subtotal    Decimal @db.Decimal(12, 2)
  deliveryFee Decimal @db.Decimal(12, 2)
  discount    Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  // Delivery address snapshot (BR: not editable after pickup — kept immutable).
  recipientName String
  phone         String
  addressLine   String
  city          String
  province      String
  postalCode    String?
  latitude      Float?
  longitude     Float?
  notes         String?

  /// Customer's preferred delivery time-window, a free-form client label
  /// (e.g. "2026-07-20 09:00-12:00"). Not slot-checked — display/reference only.
  deliveryWindow String?

  /// Display name of the assigned courier (set at DRIVER_ASSIGNED). Powers "antaran {name}".
  driverName    String?

  /// Assigned courier's phone (set at DRIVER_ASSIGNED), snapshotted from dispatch so
  /// the customer can call the driver from order tracking without a cross-service lookup.
  driverPhone   String?

  /// Customer-facing ETA, set at ON_DELIVERY by delivery-service (distance ÷ assumed
  /// urban speed). Null until the courier starts the run. Powers the tracking "tiba ~".
  estimatedArrivalAt DateTime?

  /// Amount refunded on this order, set by payment-service when a refund settles.
  /// Null = no refund. Powers per-depot refund reconciliation (22a).
  refundedAmount Decimal? @db.Decimal(12, 2)

  items   OrderItem[]
  history OrderStatusHistory[]
  review  OrderReview?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([depotId])
  // Reporting + paginated list all filter/sort on createdAt; composites back the
  // status- and depot-scoped report predicates (audit DB-3).
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([depotId, createdAt])
  @@map("orders")
}

/// A price-snapshotted order line. `unitPrice`/`productName`/`sku` are frozen at
/// checkout so the order total never changes if the catalog later does.
model OrderItem {
  id          String  @id @default(uuid()) @db.Uuid
  orderId     String  @db.Uuid
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String  @db.Uuid
  productName String
  sku         String
  unit        String
  unitPrice   Decimal @db.Decimal(12, 2)
  quantity    Int
  lineTotal   Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@map("order_items")
}

/// Append-only audit of every status transition (BR-012 traceability).
model OrderStatusHistory {
  id        String      @id @default(uuid()) @db.Uuid
  orderId   String      @db.Uuid
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  // Actor that made the change: a user id (UUID) OR a system service label
  // (e.g. 'payment-service' for the settled-payment auto-confirm). Plain text,
  // not @db.Uuid — a service name is not a UUID and Prisma would reject it.
  changedBy String?
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

enum SubscriptionFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

/// Recurring galon delivery (spec 7b). A due ACTIVE subscription auto-places an
/// order for its single line, then advances nextDeliveryAt by the frequency.
model Subscription {
  id         String                @id @default(uuid()) @db.Uuid
  customerId String                @db.Uuid
  productId  String                @db.Uuid
  productName String
  unit       String
  quantity   Int
  frequency  SubscriptionFrequency
  status     SubscriptionStatus    @default(ACTIVE)
  nextDeliveryAt DateTime

  // Delivery address snapshot used for every scheduled order.
  recipientName String
  phone         String
  addressLine   String
  city          String
  province      String
  postalCode    String?
  latitude      Float?
  longitude     Float?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status, nextDeliveryAt])
  @@map("subscriptions")
}

/// Customer rating of a completed order (spec 7c). One review per order.
model OrderReview {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @unique @db.Uuid
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String   @db.Uuid
  rating     Int
  aspects    String[]
  comment    String?
  tipAmount  Int      @default(0)
  createdAt  DateTime @default(now())

  @@map("order_reviews")
}
