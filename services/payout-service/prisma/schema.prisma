// Hydromart payout-service data model (design "Keuangan · usulan": Payout & komisi).
// Owns a per-franchise-owner cash ledger (sales settlements, HQ commission, stock
// purchases, withdrawals) and withdrawal requests. Balance = sum of signed ledger
// amounts. Append-only ledger; withdrawals also post a matching debit entry.

generator client {
  provider = "prisma-client-js"
  // Service-local output so it never clobbers other services' @prisma/client.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("PAYOUT_DATABASE_URL")
}

/// Ledger entry kind. Credits (positive amount): SALE_SETTLEMENT. Debits (negative):
/// COMMISSION (HQ share), STOCK_PURCHASE, WITHDRAWAL. ADJUSTMENT may be either sign.
enum LedgerEntryType {
  SALE_SETTLEMENT
  COMMISSION
  STOCK_PURCHASE
  WITHDRAWAL
  ADJUSTMENT
}

/// Withdrawal lifecycle. PROCESSING on request; PAID once the bank transfer clears;
/// FAILED if the transfer is rejected (a compensating credit re-posts to the ledger).
enum WithdrawalStatus {
  PROCESSING
  PAID
  FAILED
}

/// Courier cash-book entry kind. Credits (+): EARNING, INCENTIVE (monthly tier bonus).
/// Debits (-): DEDUCTION (e.g.
/// break overage), CASH_VARIANCE (COD shortfall charged, slice 13), WITHDRAWAL.
/// ADJUSTMENT may be either sign. Kept parallel to LedgerEntryType (franchise money)
/// rather than generalised — the two ledgers never share a balance.
enum CourierLedgerEntryType {
  EARNING
  INCENTIVE
  DEDUCTION
  CASH_VARIANCE
  WITHDRAWAL
  ADJUSTMENT
}

/// Append-only cash-book entry for one franchise owner (optionally attributed to a depot).
model LedgerEntry {
  id               String          @id @default(uuid()) @db.Uuid
  franchiseOwnerId String          @db.Uuid
  depotId          String?         @db.Uuid
  type             LedgerEntryType
  /// Signed IDR amount: positive = credit (balance up), negative = debit.
  amount           Decimal         @db.Decimal(14, 2)
  description      String
  occurredAt       DateTime        @default(now())
  createdAt        DateTime        @default(now())

  @@index([franchiseOwnerId, occurredAt])
  @@map("ledger_entries")
}

/// Per-depot franchise commission scheme (design 21c "Skema komisi"). Effective-dated:
/// the row with the latest effectiveDate is a depot's current payout percentage.
/// "Terapkan skema baru" appends a new row per depot rather than mutating in place, so
/// the change is auditable and time-scoped. Append-only — never updated.
model CommissionScheme {
  id            String   @id @default(uuid()) @db.Uuid
  depotId       String   @db.Uuid
  /// Denormalized owner display name (design shows the owner beside each depot).
  ownerName     String?
  /// Franchise payout percentage (0..100), e.g. 20.00.
  pct           Decimal  @db.Decimal(5, 2)
  effectiveDate DateTime
  createdAt     DateTime @default(now())

  // Current-scheme lookup reads the newest effectiveDate per depot.
  @@index([depotId, effectiveDate])
  @@map("commission_schemes")
}

/// Per-depot courier earning rule (design 6b). Effective-dated like CommissionScheme:
/// the newest effectiveDate for a depot is its current rule; a row with depotId NULL
/// is the network default used when a depot has no rule of its own. Append-only.
/// Applied in payout-service (not delivery-service) so the money math has one home.
model CourierEarningRule {
  id      String  @id @default(uuid()) @db.Uuid
  /// NULL = network default rule.
  depotId String? @db.Uuid
  /// Flat pay per completed delivery (IDR).
  baseFare      Decimal @db.Decimal(12, 2)
  /// Added on top of baseFare when the delivery completes within peak hours.
  peakBonus     Decimal @db.Decimal(12, 2)
  /// Added when the delivery beat its SLA (onTime, decided by delivery-service).
  onTimeBonus   Decimal @db.Decimal(12, 2)
  /// Peak window [start, end) in local hour-of-day, e.g. 17..20.
  peakStartHour Int
  peakEndHour   Int
  /// Monthly earnings target shown to the courier (IDR); 0 = no target configured.
  monthlyTarget Decimal @db.Decimal(14, 2) @default(0)
  effectiveDate DateTime
  createdAt     DateTime @default(now())

  tiers CourierIncentiveTier[]

  @@index([depotId, effectiveDate])
  @@map("courier_earning_rules")
}

/// Monthly delivery-count incentive ladder attached to one earning rule. Immutable with
/// its parent rule (rules are append-only), so a paid bonus stays reproducible.
model CourierIncentiveTier {
  id         String  @id @default(uuid()) @db.Uuid
  ruleId     String  @db.Uuid
  /// Completed deliveries in the month that unlock the bonus.
  deliveries Int
  /// One-off IDR credit posted when the rung is reached.
  bonus      Decimal @db.Decimal(12, 2)

  rule CourierEarningRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, deliveries])
  @@map("courier_incentive_tiers")
}

/// Append-only courier cash-book entry. Balance = signed sum of amounts. sourceRef
/// makes upstream pushes idempotent (a re-delivered event re-uses the same ref and
/// is a no-op) — the delivery→payout push is at-least-once.
model CourierLedgerEntry {
  id        String                 @id @default(uuid()) @db.Uuid
  courierId String                 @db.Uuid
  depotId   String?                @db.Uuid
  type      CourierLedgerEntryType
  /// Signed IDR amount: positive = credit (balance up), negative = debit.
  amount    Decimal                @db.Decimal(14, 2)
  description String
  /// Idempotency key for the source event, e.g. "earning:<deliveryId>". Unique.
  sourceRef String? @unique
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([courierId, occurredAt])
  @@map("courier_ledger_entries")
}

/// Expense-claim lifecycle (design 6a). PENDING on submit unless auto-approved under
/// the threshold; a reviewer moves it to APPROVED (credits the courier ledger) or REJECTED.
enum ExpenseClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Reimbursable expense kinds a courier can claim.
enum ExpenseCategory {
  FUEL
  PARKING_TOLL
  VEHICLE_REPAIR
  OTHER
}

/// A courier's out-of-pocket expense claim (design 6a). Approval credits the courier
/// ledger (ADJUSTMENT) via sourceRef "expense:<id>" so the credit is idempotent.
model ExpenseClaim {
  id          String             @id @default(uuid()) @db.Uuid
  courierId   String             @db.Uuid
  /// Courier's assigned depot (client-supplied) so a reviewer can filter by depot.
  depotId     String?            @db.Uuid
  category    ExpenseCategory
  /// Positive IDR amount claimed.
  amount      Decimal            @db.Decimal(14, 2)
  description String
  /// Optional receipt photo URL. Retention/lifecycle for this asset is an ops concern
  /// (separate bucket/prefix from PoD) — this model only stores the reference.
  receiptUrl  String?
  status      ExpenseClaimStatus @default(PENDING)
  /// Reviewer staff user id (null when auto-approved under the threshold).
  reviewedBy  String?            @db.Uuid
  reviewedAt  DateTime?
  reviewNote  String?
  /// The credited CourierLedgerEntry id once approved (null until credited).
  ledgerEntryId String?          @db.Uuid
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([depotId, status])
  @@index([courierId, createdAt])
  @@map("expense_claims")
}

/// A courier's request to cash out earnings to their bank account (design 2c). Parallel
/// to the franchise Withdrawal; the matching debit posts to CourierLedgerEntry.
model CourierWithdrawal {
  id             String           @id @default(uuid()) @db.Uuid
  courierId      String           @db.Uuid
  /// Positive IDR amount requested.
  amount         Decimal          @db.Decimal(14, 2)
  /// Masked destination shown in the UI, e.g. "BCA ···· 4821".
  bankAccountRef String
  status         WithdrawalStatus @default(PROCESSING)
  /// Human-facing reference, e.g. "WD-20260718-4821". Unique.
  reference      String           @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([courierId, createdAt])
  @@map("courier_withdrawals")
}

/// A franchise owner's request to cash out available balance to their bank account.
model Withdrawal {
  id               String           @id @default(uuid()) @db.Uuid
  franchiseOwnerId String           @db.Uuid
  /// Positive IDR amount requested.
  amount           Decimal          @db.Decimal(14, 2)
  /// Masked destination shown in the UI, e.g. "BCA ···· 4821".
  bankAccountRef   String
  status           WithdrawalStatus @default(PROCESSING)
  /// Human-facing reference, e.g. "WD-20260710-4821". Unique.
  reference        String           @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([franchiseOwnerId, createdAt])
  @@map("withdrawals")
}
