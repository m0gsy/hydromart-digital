NODE_ENV=development
PAYOUT_SERVICE_PORT=3016
PAYOUT_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_payout?schema=public
# JWT_ACCESS_SECRET is shared across every service. Set it ONCE in the repo-root
# .env (each service loads it via the ../../.env fallback in ConfigModule).
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
# HQ commission rate on gross sales settlements (reporting only). 0.05 = 5%.
PAYOUT_COMMISSION_RATE=0.05
