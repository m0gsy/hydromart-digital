// Hydromart payment-service data model (PRD Module 5, Payments).
// Owns the payment record for an order and its refunds. Linked to an order by
// orderId only (loose coupling — the order-service owns the order itself).

generator client {
  provider = "prisma-client-js"
  // Service-local output so it never clobbers other services' @prisma/client.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("PAYMENT_DATABASE_URL")
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
  EWALLET
  VA
}

// PENDING → PAID | FAILED | CANCELLED; PAID → REFUNDED. Terminal: FAILED,
// CANCELLED, REFUNDED. Online-paid cancellation goes through REFUNDED.
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

// HQ refund-approval state for a payment (feature 14a). NONE = no approval needed
// (refunded directly, under the HQ threshold). PENDING = queued for HQ review.
// APPROVED/REJECTED = decided by finance/super-admin.
enum RefundApproval {
  NONE
  PENDING
  APPROVED
  REJECTED
}

/// One payment attempt for an order. A new attempt is created if a prior one
/// failed/was cancelled; at most one PENDING/PAID row exists per order.
model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  orderId      String        @db.Uuid
  customerId   String        @db.Uuid
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  amount       Decimal       @db.Decimal(12, 2)
  /// Provider charge reference / VA number / QRIS payload. Null for CASH.
  reference    String?
  /// Human-readable payment instruction shown to the customer.
  instruction  String?
  /// Opaque provider payload snapshot (JSON string) for audit/reconciliation.
  gatewayData  String?
  paidAt       DateTime?
  failedAt     DateTime?

  /// COD only: cash the customer handed over and the change given back, recorded
  /// at confirm time (design 7a). Null for online/transfer settlements.
  cashReceived Decimal?  @db.Decimal(12, 2)
  changeGiven  Decimal?  @db.Decimal(12, 2)

  refundedAt     DateTime?
  refundReason   String?
  refundedAmount Decimal?  @db.Decimal(12, 2)
  /// HQ refund-approval state. High-value refunds park at PENDING until decided.
  refundApproval RefundApproval @default(NONE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([refundApproval])
  // Audit DB-1: a partial UNIQUE index enforcing one active (PENDING/PAID) payment
  // per order is added by migration 20260718140500_payment_one_active_per_order
  // (Prisma can't express a partial unique index here). The initiate() pre-check is
  // the fast path; this index is the real race guard.
  @@map("payments")
}

/// Singleton tax & invoice settings (feature 19f). One active row; feeds the
/// invoice-template preview (24d). PPN %, price-inclusive toggle, invoice-number
/// format and the company's legal identity.
model TaxSettings {
  id               String   @id @default(uuid()) @db.Uuid
  ppnPercent       Decimal  @db.Decimal(5, 2)
  priceIncludesTax Boolean  @default(true)
  invoiceFormat    String
  companyName      String
  npwp             String
  address          String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("tax_settings")
}
