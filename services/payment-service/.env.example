NODE_ENV=development
PAYMENT_SERVICE_PORT=3005
PAYMENT_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_payment?schema=public
# Must match auth-service JWT_ACCESS_SECRET (verifies its access tokens).
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
# Payment gateway used for online methods (QRIS/E-Wallet/VA). Leave base URL blank
# in dev; online charges will then fail closed until a gateway is configured.
PAYMENT_GATEWAY_BASE_URL=
PAYMENT_GATEWAY_API_KEY=
# Shared secret the gateway signs webhook callbacks with (HMAC-SHA256 over the body).
PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret-min-16-chars
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
