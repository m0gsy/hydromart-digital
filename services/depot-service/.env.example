NODE_ENV=development
DEPOT_SERVICE_PORT=3007
DEPOT_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_depot?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
# Low-stock alerting (FR-074), optional. Both blank = disabled (no alert emitted).
CRM_SERVICE_URL=http://localhost:3012
DEPOT_ALERT_PHONE=
