// Hydromart depot-service data model (PRD Module 10 Depot Management + Module 9 Inventory).
// Owns depots (ownership type, operating hours, delivery zone/fee, holidays) and their
// per-depot stock lines (Air/Galon/Tutup/Segel/Produk) with an append-only movement ledger.

generator client {
  provider = "prisma-client-js"
  // Service-local output so it never clobbers other services' @prisma/client.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DEPOT_DATABASE_URL")
}

/// Franchise (Waralaba) vs company-owned (HKP). PRD: every depot has exactly one type.
enum OwnershipType {
  WARALABA
  HKP
}

/// Stock line kinds (PRD FR-067..071). PRODUK lines reference the product catalog.
enum InventoryItemType {
  AIR
  GALON
  TUTUP
  SEGEL
  PRODUK
}

/// Ledger entry kind (PRD FR-072 adjustment, FR-073 opname; RECEIPT seeds initial stock;
/// SALE deducts sold quantities when an order completes).
enum StockMovementType {
  RECEIPT
  ADJUSTMENT
  OPNAME
  SALE
}

/// Lifecycle of a per-order stock hold (reserve at checkout -> release on cancel / consume on completion).
enum ReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
}

model Depot {
  id             String        @id @default(uuid()) @db.Uuid
  /// Human-facing short code, unique across the network (e.g. "JKT-01").
  code           String        @unique
  name           String
  ownershipType  OwnershipType
  address        String
  city           String
  province       String
  lat            Float
  lng            Float
  /// Service/delivery radius in km (FR-077/FR-078).
  serviceRadiusKm Float        @default(5)
  /// Flat delivery fee for this depot in IDR (FR-079).
  deliveryFee    Decimal       @db.Decimal(12, 2)
  /// Minimum order amount in IDR; per-depot policy. Null = no minimum.
  minOrderAmount Decimal?      @db.Decimal(12, 2)
  /// Franchise owner (account id) who manages this depot. Null = unassigned / company-run.
  ownerId        String?       @db.Uuid
  /// Per-depot payment destination shown to a paying customer (franchise model: money goes
  /// direct to each depot, manually confirmed, no gateway). All optional until an owner sets them.
  paymentBankName          String?
  paymentBankAccountNumber String?
  paymentBankAccountHolder String?
  /// URL of the depot's static QRIS image.
  paymentQrisImageUrl      String?
  /// Weekly operating hours (FR-076): { mon: {open,close}, ... }.
  operatingHours Json          @default("{}")
  /// Closure dates (FR-080): [{ date: "2026-08-17", label?: "..." }].
  holidays       Json          @default("[]")
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  inventory      InventoryItem[]
  gallonReturns  GallonReturn[]
  gallonIssues   GallonIssue[]
  // Console/manager models (DB-5): FK back-relations. Config models cascade on depot
  // delete; financial/audit models (POs, approvals, cashbook, disputes) restrict.
  priceOverrideProposals PriceOverrideProposal[]
  pricingRules           PricingRule[]
  incidents              Incident[]
  suppliers              Supplier[]
  purchaseOrders         PurchaseOrder[]
  approvals              Approval[]
  shiftAssignments       ShiftAssignment[]
  depotTargets           DepotTarget[]
  cashbookEntries        CashbookEntry[]
  orderDisputes          OrderDispute[]
  maintenanceItems       MaintenanceItem[]
  wholesaleTiers         WholesaleTier[]
  subscriptions          Subscription[]
  huddleNotes            HuddleNote[]
  shiftHandovers         ShiftHandover[]

  @@index([active])
  @@index([ownershipType])
  @@index([ownerId])
  @@map("depots")
}

/// Condition of returned empty gallons: reusable stock vs. damaged/retired.
enum GallonCondition {
  GOOD
  DAMAGED
}

/// Empty-gallon return / deposit refund ledger (PRD Module 11 retur galon).
/// One append-only row per return event at a depot: empties handed back and the
/// deposit refunded. Standalone ledger — not yet wired into GALON stock counts.
model GallonReturn {
  id              String          @id @default(uuid()) @db.Uuid
  depotId         String          @db.Uuid
  depot           Depot           @relation(fields: [depotId], references: [id], onDelete: Cascade)
  /// Customer who returned the empties (optional — walk-ins may be anonymous).
  customerId      String?         @db.Uuid
  /// Order the return happened against (set when a courier records it at delivery
  /// handover, design 2e; null for a walk-in counter return).
  orderId         String?         @db.Uuid
  /// Number of empty gallons handed back.
  quantity        Int
  condition       GallonCondition @default(GOOD)
  /// Deposit refunded to the customer in IDR (0 = no deposit / store credit).
  /// Courier-recorded returns derive this server-side (GALLON_DEPOSIT_IDR × quantity).
  depositRefunded Decimal         @db.Decimal(12, 2) @default(0)
  note            String?
  /// Staff member (or courier) who recorded the return.
  actorId         String
  createdAt       DateTime        @default(now())

  @@index([depotId, createdAt])
  @@index([orderId])
  @@map("gallon_returns")
}

/// Empty-gallon issue / deposit-held ledger (PRD Module 11c — mirror of retur galon).
/// One append-only row per issue event at a depot: empties handed out on deposit.
/// "Galon di pelanggan / belum kembali" = SUM(issued.quantity) − SUM(returned.quantity).
/// Manual ledger — auto-ingest from an order-completed event is a future follow-up.
model GallonIssue {
  id          String   @id @default(uuid()) @db.Uuid
  depotId     String   @db.Uuid
  depot       Depot    @relation(fields: [depotId], references: [id], onDelete: Cascade)
  /// Customer who took the empties (optional — walk-ins may be anonymous).
  customerId  String?  @db.Uuid
  /// Number of empty gallons issued.
  quantity    Int
  /// Deposit held from the customer in whole IDR (0 = no deposit).
  depositHeld Int      @default(0)
  note        String?
  /// Staff member who recorded the issue.
  actorId     String
  createdAt   DateTime @default(now())

  @@index([depotId, createdAt])
  @@map("gallon_issues")
}

model InventoryItem {
  id           String            @id @default(uuid()) @db.Uuid
  depotId      String            @db.Uuid
  depot        Depot             @relation(fields: [depotId], references: [id], onDelete: Cascade)
  itemType     InventoryItemType
  /// Set only for PRODUK lines: the catalog product this line tracks.
  productId    String?           @db.Uuid
  /// Display label, e.g. "Air RO", "Galon 19L", or the product name for PRODUK lines.
  label        String
  unit         String
  quantity     Int               @default(0)
  /// Units held by ACTIVE order reservations. Sellable stock = quantity - reserved.
  reserved     Int               @default(0)
  minimumStock Int               @default(0)
  /// Per-depot sell price override in IDR (PRODUK lines only). Null = use the
  /// catalog base price. Lets franchise (WARALABA) depots price independently.
  sellPrice    Decimal?          @db.Decimal(12, 2)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  movements    StockMovement[]
  reservations StockReservation[]

  // Best-effort DB uniqueness for PRODUK lines (productId set). Non-PRODUK singletons
  // (productId NULL) slip past this because Postgres treats NULLs as distinct — they're
  // now also enforced by a partial unique index on (depotId, itemType) WHERE productId IS
  // NULL, added in migration 20260718170000_inventory_singleton_unique (DB-11; Prisma DSL
  // can't express a partial unique index, so it lives in raw SQL there).
  @@unique([depotId, itemType, productId])
  @@index([depotId])
  @@map("inventory_items")
}

/// A per-order hold on a stock line placed at checkout. Prevents overselling
/// between checkout and completion; released on cancel, consumed on completion.
model StockReservation {
  id        String            @id @default(uuid()) @db.Uuid
  itemId    String            @db.Uuid
  item      InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  orderId   String            @db.Uuid
  quantity  Int
  status    ReservationStatus @default(ACTIVE)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // One reservation per line per order (idempotent reserve/release/consume).
  @@unique([itemId, orderId])
  @@index([itemId])
  @@map("stock_reservations")
}

model StockMovement {
  id             String            @id @default(uuid()) @db.Uuid
  itemId         String            @db.Uuid
  item           InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type           StockMovementType
  /// Signed change applied to quantity (+receipt/positive adjust, -consume, opname variance).
  delta          Int
  quantityBefore Int
  quantityAfter  Int
  reason         String?
  /// User id of the staff member who recorded the movement.
  actorId        String
  /// Set only on SALE movements: the order that consumed this stock. Enables
  /// idempotent order->inventory deduction (a retried COMPLETED never double-deducts).
  orderId        String?           @db.Uuid
  createdAt      DateTime          @default(now())

  @@unique([itemId, orderId])
  @@index([itemId])
  @@map("stock_movements")
}

/// Prospective-franchise application lifecycle (HQ approvals queue, design 5a/5b).
/// PENDING -> DOC_VERIFICATION -> SURVEY -> APPROVED / REJECTED.
enum FranchiseAppStage {
  PENDING
  DOC_VERIFICATION
  SURVEY
  APPROVED
  REJECTED
}

/// An HQ-reviewed application to open a new franchise (WARALABA) depot. The proposed
/// depot fields double as the onboard-form prefill returned on approval. The document
/// checklist (KTP&NPWP, location-ownership proof, capital deposit, field survey) is a
/// JSON map of item -> status, mirroring how the schema stores operatingHours/holidays.
model FranchiseApplication {
  id                      String            @id @default(uuid()) @db.Uuid
  applicantName           String
  applicantPhone          String
  /// Proposed depot short code (becomes the depot `code` on onboard).
  proposedCode            String
  proposedName            String
  city                    String
  province                String
  lat                     Float
  lng                     Float
  /// Applicant's stated investment (IDR).
  investmentAmount        Decimal           @db.Decimal(14, 2)
  /// Applicant's projected monthly revenue (IDR).
  projectedMonthlyRevenue Decimal           @db.Decimal(14, 2)
  /// { ktpNpwp, locationProof, capitalDeposit, fieldSurvey } each = PENDING|VERIFIED|REJECTED.
  checklist               Json              @default("{}")
  stage                   FranchiseAppStage @default(PENDING)
  submittedAt             DateTime          @default(now())
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  // Oldest-first SLA queue reads by (stage, submittedAt).
  @@index([stage, submittedAt])
  @@map("franchise_applications")
}

enum PricingAdjustType {
  PERCENT
  FIXED
}

/// HQ decision on a depot's price-override proposal (design 7a). PENDING until HQ
/// approves (creates the winning pricing rule) or rejects it.
enum PriceOverrideStatus {
  PENDING
  APPROVED
  REJECTED
}

/// A depot manager's proposal to override a product's price at their depot (design 7a).
/// HQ approves (priority-wins) or rejects. On approval a PricingRule is created through
/// the existing pricing mechanism; this row only records the proposal + decision.
/// depotName/productName/currentPrice are denormalized snapshots for the HQ queue view
/// (mirrors CommissionScheme.ownerName): the depot-service does not own product names.
model PriceOverrideProposal {
  id           String              @id @default(uuid()) @db.Uuid
  depotId      String              @db.Uuid
  depot        Depot               @relation(fields: [depotId], references: [id], onDelete: Cascade)
  depotName    String
  productId    String              @db.Uuid
  productName  String
  /// Snapshot of the depot's current price at propose time (IDR).
  currentPrice Decimal             @db.Decimal(12, 2)
  adjustType   PricingAdjustType
  /// PERCENT = signed percent; FIXED = signed rupiah delta (same semantics as PricingRule).
  value        Decimal             @db.Decimal(12, 2)
  note         String?
  status       PriceOverrideStatus @default(PENDING)
  /// Account id of the proposing depot manager.
  proposedBy   String              @db.Uuid
  /// Account id of the HQ approver/rejecter. Null until decided.
  decidedBy    String?             @db.Uuid
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  // Newest-first queue reads by (status, createdAt).
  @@index([status, createdAt])
  @@map("price_override_proposals")
}

model PricingRule {
  id          String            @id @default(uuid()) @db.Uuid
  depotId     String            @db.Uuid
  depot       Depot             @relation(fields: [depotId], references: [id], onDelete: Cascade)
  productId   String?           @db.Uuid
  adjustType  PricingAdjustType
  value       Decimal           @db.Decimal(12, 2)
  daysOfWeek  Int[]
  startMinute Int?
  endMinute   Int?
  validFrom   DateTime?
  validUntil  DateTime?
  priority    Int               @default(0)
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([depotId])
  @@map("pricing_rules")
}

/// Kind of depot operational incident (design 6b operator "Insiden depot" + 13b manager).
enum IncidentType {
  COURIER_FALL
  VEHICLE_BREAKDOWN
  CUSTOMER_CONFLICT
  POWER_OUTAGE
  GALLON_DAMAGE
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
}

/// OPEN → IN_PROGRESS → RESOLVED lifecycle for a depot incident.
enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

/// Depot operational incidents inbox (design 6b/13b): one row per field/ops event
/// (courier fall, breakdown, complaint, outage, gallon damage) with a resolution trail.
model Incident {
  id             String           @id @default(uuid()) @db.Uuid
  depotId        String           @db.Uuid
  depot          Depot            @relation(fields: [depotId], references: [id], onDelete: Cascade)
  type           IncidentType
  severity       IncidentSeverity
  status         IncidentStatus   @default(OPEN)
  title          String
  description    String?
  /// Account id of the staff member who logged the incident.
  reportedBy     String           @db.Uuid
  /// Courier involved, if any (free text — courier need not be an account).
  courierName    String?
  /// Related order reference (e.g. "HM-...000476"), if any.
  orderRef       String?
  /// Resolution note + who/when, set when the incident is marked RESOLVED.
  resolutionNote String?
  resolvedBy     String?          @db.Uuid
  resolvedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Newest-first inbox reads by (depotId, status, createdAt).
  @@index([depotId, status, createdAt])
  @@map("incidents")
}

/// Purchase-order lifecycle (design 7a/9d): drafted → sent to supplier → goods received.
enum PoStatus {
  DRAFT
  SENT
  RECEIVED
}

/// A depot's supplier directory entry (design 11b): a vendor of raw stock
/// (galon/segel/air baku). categories is a free-text list, e.g. ["Galon 19L","Segel"].
model Supplier {
  id           String   @id @default(uuid()) @db.Uuid
  depotId      String   @db.Uuid
  depot        Depot    @relation(fields: [depotId], references: [id], onDelete: Cascade)
  name         String
  /// Short human code, unique within a depot.
  code         String
  contactPhone String?
  /// What they supply, e.g. ["Galon 19L","Segel","Air baku"].
  categories   String[]
  /// On-time delivery rate 0..1; null until enough POs land (denormalized metric).
  onTimeRate   Float?
  createdAt    DateTime @default(now())

  @@unique([depotId, code])
  @@index([depotId])
  @@map("suppliers")
}

/// A depot purchase order (design 7a/9d). `lines` is a JSON array of
/// { itemType, label, quantity, unitCostIdr }. Receiving a SENT PO posts a RECEIPT stock
/// movement per line into the depot's inventory. supplierName is a denormalized snapshot
/// so list/detail render without a supplier join.
model PurchaseOrder {
  id           String    @id @default(uuid()) @db.Uuid
  depotId      String    @db.Uuid
  depot        Depot     @relation(fields: [depotId], references: [id], onDelete: Restrict)
  /// Human PO reference, unique within a depot (e.g. "PO-A1B2C3D4").
  poNumber     String
  supplierId   String    @db.Uuid
  supplierName String
  status       PoStatus  @default(DRAFT)
  lines        Json      @default("[]")
  /// Whole IDR. subtotal = Σ(qty×unitCost); total = subtotal + shipping.
  subtotalIdr  Int
  shippingIdr  Int       @default(0)
  totalIdr     Int
  expectedAt   DateTime?
  receivedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@unique([depotId, poNumber])
  @@index([depotId, status, createdAt])
  @@map("purchase_orders")
}

/// Kind of manager approval item (design 1c/2a-2c/10c/12a).
enum ApprovalType {
  OPNAME_VARIANCE
  DEPOSIT_REFUND
  COD_VARIANCE
}

/// PENDING → APPROVED / REJECTED / HELD lifecycle for an approval item.
/// HELD parks an item for later without a final decision.
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  HELD
}

/// Depot-manager approval queue (design 1c/2a-2c/10c/12a): one row per value decision a
/// manager must sign off — stock-count loss (opname), deposit refund, COD shortfall. Small
/// values auto-pass (APPROVED at create) under the depot's threshold; larger ones wait
/// PENDING for a Tolak/Tahan/Setujui decision. payload is a per-type JSON snapshot rendered
/// on the detail screen: {system,physical,variance} | {condition,deposit} | {expected,received}.
model Approval {
  id                String         @id @default(uuid()) @db.Uuid
  depotId           String         @db.Uuid
  depot             Depot          @relation(fields: [depotId], references: [id], onDelete: Restrict)
  type              ApprovalType
  status            ApprovalStatus @default(PENDING)
  title             String
  /// Account id of the operator/system that raised the item.
  submittedBy       String         @db.Uuid
  /// Human subject of the decision (product / customer / courier name).
  subjectRef        String?
  /// Signed rupiah at stake: loss (opname), refund (deposit), shortfall (COD).
  amountIdr         Int
  /// Per-type snapshot for the detail view.
  payload           Json           @default("{}")
  /// At/under |amount| this item auto-passed without review (snapshot of the threshold).
  autoPassThreshold Int
  decisionNote      String?
  decidedBy         String?        @db.Uuid
  decidedAt         DateTime?
  createdAt         DateTime       @default(now())

  // Newest-first queue reads by (depotId, status, createdAt).
  @@index([depotId, status, createdAt])
  @@map("approvals")
}

/// Courier shift kind on a roster cell (design: operator 6d "Jadwal shift kurir" + manager 7b).
enum ShiftKind {
  MORNING
  EVENING
  OFF
}

/// Courier shift roster (design 6d/7b): one row per (staff, day) of a depot's week. weekStart
/// is the ISO date string of that week's Monday (e.g. "2026-07-14"); day is 0=Mon..6=Sun. A
/// week's grid is the set of rows sharing (depotId, weekStart).
model ShiftAssignment {
  id        String    @id @default(uuid()) @db.Uuid
  depotId   String    @db.Uuid
  depot     Depot     @relation(fields: [depotId], references: [id], onDelete: Cascade)
  staffId   String    @db.Uuid
  staffName String
  weekStart String
  day       Int
  shift     ShiftKind @default(OFF)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([depotId, weekStart, staffId, day])
  @@index([depotId, weekStart])
  @@map("shift_assignments")
}

/// Depot monthly targets (design 13a). One row per (depot, month=YYYY-MM). Actuals
/// (revenue/orders/SLA/new customers) are derived at read time from order/delivery
/// reports; this row stores only the goals a manager sets.
model DepotTarget {
  id                 String   @id @default(uuid()) @db.Uuid
  depotId            String   @db.Uuid
  depot              Depot    @relation(fields: [depotId], references: [id], onDelete: Cascade)
  /// ISO year-month, e.g. "2026-07".
  month              String
  revenueTargetIdr   Int      @default(0)
  ordersTarget       Int      @default(0)
  /// On-time SLA target as a whole percent (e.g. 96).
  slaTargetPct       Int      @default(0)
  newCustomersTarget Int      @default(0)
  updatedBy          String   @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([depotId, month])
  @@index([depotId])
  @@map("depot_targets")
}

/// Kind of manual cashbook movement (design 14c). Derived movements (COD settlement in,
/// PO payment out) may be posted by other flows later; for now entries are manager-entered.
enum CashDirection {
  IN
  OUT
}

/// Depot cashbook / daily cash flow ledger (design 14c). Append-only rows of cash in
/// (COD settlement, walk-in sale) and out (PO payment, courier commission, expenses),
/// summed per day for an opening/closing balance.
model CashbookEntry {
  id         String        @id @default(uuid()) @db.Uuid
  depotId    String        @db.Uuid
  depot      Depot         @relation(fields: [depotId], references: [id], onDelete: Restrict)
  direction  CashDirection
  /// Short category, e.g. "COD", "PO", "KOMISI", "SEWA".
  category   String
  label      String
  amountIdr  Int
  occurredAt DateTime      @default(now())
  /// Optional link to the source (settlement id, PO number) when auto-posted.
  sourceRef  String?
  actorId    String        @db.Uuid
  createdAt  DateTime      @default(now())

  @@index([depotId, occurredAt])
  @@map("cashbook_entries")
}

/// Kind of customer order dispute (design 15c).
enum DisputeCategory {
  WRONG_ITEM
  NOT_RECEIVED
  OVERCHARGED
  QUALITY
  OTHER
}

/// OPEN → RESOLVED / REJECTED lifecycle of an order dispute.
enum DisputeStatus {
  OPEN
  RESOLVED
  REJECTED
}

/// How a resolved dispute was settled (design 15c).
enum DisputeResolution {
  REFUND
  RESEND
  REJECTED
}

/// Customer order disputes (design 15c): a claim against a delivered order (wrong item,
/// not received, overcharged, quality) and the manager's resolution.
model OrderDispute {
  id             String             @id @default(uuid()) @db.Uuid
  depotId        String             @db.Uuid
  depot          Depot              @relation(fields: [depotId], references: [id], onDelete: Restrict)
  orderRef       String
  customerName   String
  category       DisputeCategory
  description    String
  /// Amount in dispute (IDR), for the resolution quote.
  amountIdr      Int                @default(0)
  courierName    String?
  status         DisputeStatus      @default(OPEN)
  resolution     DisputeResolution?
  resolutionNote String?
  raisedBy       String             @db.Uuid
  resolvedBy     String?            @db.Uuid
  resolvedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([depotId, status, createdAt])
  @@map("order_disputes")
}

/// Equipment health for a maintenance item (design 14a). DUE = overdue; SOON = within
/// the warning window; HEALTHY otherwise; NEW = recently replaced.
enum MaintenanceStatus {
  DUE
  SOON
  HEALTHY
  NEW
}

/// Depot equipment maintenance schedule (design 14a): RO filter, refill machine, genset,
/// UV lamp — each with a service interval and next-due date. `status` is derived from
/// nextDueAt at write time and recomputed on read.
model MaintenanceItem {
  id            String            @id @default(uuid()) @db.Uuid
  depotId       String            @db.Uuid
  depot         Depot             @relation(fields: [depotId], references: [id], onDelete: Cascade)
  name          String
  /// Short category label, e.g. "Filter RO", "Genset".
  category      String
  intervalDays  Int
  lastServicedAt DateTime?
  nextDueAt     DateTime
  status        MaintenanceStatus @default(HEALTHY)
  note          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([depotId, nextDueAt])
  @@map("maintenance_items")
}

/// B2B wholesale price tier (design 15d): a quantity band mapping to a per-unit price for
/// bulk buyers (offices, restaurants). productId null = applies to the depot's default gallon.
model WholesaleTier {
  id        String   @id @default(uuid()) @db.Uuid
  depotId   String   @db.Uuid
  depot     Depot    @relation(fields: [depotId], references: [id], onDelete: Cascade)
  productId String?  @db.Uuid
  label     String
  /// Inclusive lower bound of the quantity band.
  minQty    Int
  /// Inclusive upper bound; null = open-ended (e.g. "50+").
  maxQty    Int?
  priceIdr  Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([depotId])
  @@map("wholesale_tiers")
}

/// Recurring-order cadence (design 16b).
enum SubscriptionCadence {
  DAILY
  EVERY_3_DAYS
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

/// Customer recurring subscription (design 16b): a standing order (N gallons on a cadence)
/// that seeds an order in the queue on its run date. Auto-order generation is a scheduler
/// follow-up; this row is the definition + status the manager manages.
model Subscription {
  id           String              @id @default(uuid()) @db.Uuid
  depotId      String              @db.Uuid
  depot        Depot               @relation(fields: [depotId], references: [id], onDelete: Cascade)
  customerId   String?             @db.Uuid
  customerName String
  productLabel String
  quantity     Int
  cadence      SubscriptionCadence
  status       SubscriptionStatus  @default(ACTIVE)
  nextRunAt    DateTime?
  note         String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([depotId, status])
  @@map("subscriptions")
}

/// Weekly team huddle (design 13c): one row per (depot, weekStart Monday). agenda and
/// actionItems are JSON arrays — agenda [{title,note}], actionItems [{text,assignee,done}].
model HuddleNote {
  id          String   @id @default(uuid()) @db.Uuid
  depotId     String   @db.Uuid
  depot       Depot    @relation(fields: [depotId], references: [id], onDelete: Cascade)
  /// ISO date of the week's Monday, e.g. "2026-07-14".
  weekStart   String
  heldAt      DateTime @default(now())
  /// "8 dari 9 hadir" style free text.
  attendance  String?
  agenda      Json     @default("[]")
  actionItems Json     @default("[]")
  recordedBy  String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([depotId, weekStart])
  @@index([depotId])
  @@map("huddle_notes")
}

/// Shift handover checklist (design 14d): a signed record passing a depot from one shift to
/// the next. items is a JSON array of { title, subtext, state: DONE|PARTIAL|PENDING }.
model ShiftHandover {
  id        String    @id @default(uuid()) @db.Uuid
  depotId   String    @db.Uuid
  depot     Depot     @relation(fields: [depotId], references: [id], onDelete: Cascade)
  /// e.g. "Pagi", "Sore".
  fromShift String
  toShift   String
  fromStaff String
  toStaff   String
  items     Json      @default("[]")
  note      String?
  /// Null until both operators sign the handover.
  signedAt  DateTime?
  recordedBy String   @db.Uuid
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([depotId, createdAt])
  @@map("shift_handovers")
}

/// Per-depot/global overridable service settings (key-value, GLOBAL falls back to DEPOT).
model ServiceSetting {
  id        String   @id @default(uuid())
  scope     String   // 'GLOBAL' | 'DEPOT'
  depotId   String?  @map("depot_id")
  key       String
  value     String
  updatedBy String   @map("updated_by")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([scope, depotId])
  @@map("service_settings")
}
