NODE_ENV=development
HR_SERVICE_PORT=3018
HR_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_hr?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here.
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
PRICING_TZ=Asia/Jakarta
# --- Attendance / payroll boot-time defaults (business-tunable via /settings) ---
HR_WORK_START_TIME=08:00
HR_LATE_TOLERANCE_MINUTES=15
HR_LATE_DEDUCTION_IDR=10000
HR_DAILY_RATE_TRAINING_IDR=30000
HR_ABSENCE_DEDUCTION_IDR=0
HR_STANDARD_WORKING_MINUTES=480
# --- Face recognition (onnxruntime-node ArcFace, runs in-process; no cloud) ---
# Match = cosine similarity >= HR_FACE_MATCH_THRESHOLD. Enroll rejects a face whose
# cosine to ANOTHER employee >= HR_FACE_DUPLICATE_THRESHOLD (duplicate prevention).
FACE_VERIFIER_DRIVER=onnx
HR_FACE_MATCH_THRESHOLD=0.62
HR_FACE_DUPLICATE_THRESHOLD=0.75
HR_FACE_MODEL_PATH=./models/arcface.onnx
# --- Photo storage (reuses the shared StoragePort; S3-compatible or local disk) ---
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./var/uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:3018/uploads
