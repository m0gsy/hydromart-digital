// Hydromart hr-service data model (HRIS Lite).
// Owns employees, face embeddings, face-recognition attendance, payroll (auto-generated
// from attendance), bonuses, deductions, performance reviews, and an HR audit trail.
//
// Cross-service references (depotId -> depot-service, authSubjectId -> auth-service) are
// plain UUID columns, NOT foreign keys: each microservice owns its own database.

generator client {
  provider = "prisma-client-js"
  // Service-local output so it never clobbers other services' @prisma/client.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("HR_DATABASE_URL")
}

/// Employment classification. Drives the default salary policy (PRD Payroll).
enum EmploymentStatus {
  TRAINING
  PROBATION
  PERMANENT
  DEPOT_MANAGER
}

/// How base pay is computed: per present-day vs a fixed monthly figure.
enum SalaryType {
  DAILY
  MONTHLY
}

/// Employee lifecycle (soft-delete: RESIGNED/INACTIVE stay in the table for history).
enum EmployeeStatus {
  ACTIVE
  INACTIVE
  RESIGNED
}

/// Daily attendance outcome derived from check-in time + holiday/leave calendar.
enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  LEAVE
  HOLIDAY
}

/// Monthly payroll lifecycle. Only DRAFT is re-generatable; APPROVED/PAID are locked.
enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

/// A signed line on a payslip. BASE/BONUS/ADJUSTMENT add; DEDUCTION subtracts.
enum PayrollItemKind {
  BASE
  BONUS
  DEDUCTION
  ADJUSTMENT
}

enum BonusType {
  ATTENDANCE
  PERFORMANCE
  SALES
  DEPOT
  MANUAL
}

enum DeductionType {
  LATE
  ABSENCE
  MANUAL
  CASH_ADVANCE
  OTHER
}

/// An internal employee. Identity is REUSED from auth-service when the person has a
/// login (authSubjectId = auth Customer.id); employees without a login carry a null.
model Employee {
  id               String           @id @default(uuid()) @db.Uuid
  /// Human-facing staff code, unique network-wide (e.g. "HR-0001").
  employeeCode     String           @unique
  /// auth-service account id for self-service (My Attendance/Payroll/Profile). Unique,
  /// nullable — an employee may exist in HR before (or without) ever getting a login.
  authSubjectId    String?          @unique @db.Uuid
  fullName         String
  photoUrl         String?
  phone            String
  email            String?
  /// Home depot (depot-service Depot.id). Drives DepotScopeGuard tenant isolation.
  depotId          String           @db.Uuid
  position         String
  employmentStatus EmploymentStatus
  joinDate         DateTime         @db.Date
  salaryType       SalaryType
  /// Base pay in IDR. dailyRate for DAILY, monthlyRate for MONTHLY (the other is null).
  dailyRate        Decimal?         @db.Decimal(12, 2)
  monthlyRate      Decimal?         @db.Decimal(12, 2)
  bankName         String?
  bankAccount      String?
  emergencyName    String?
  emergencyPhone   String?
  status           EmployeeStatus   @default(ACTIVE)
  createdBy        String?          @db.Uuid
  updatedBy        String?          @db.Uuid
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  history          EmploymentHistory[]
  faceEmbeddings   FaceEmbedding[]
  attendance       Attendance[]
  bonuses          Bonus[]
  deductions       Deduction[]
  reviews          PerformanceReview[]
  payrolls         Payroll[]

  @@index([depotId])
  @@index([status])
  @@map("employees")
}

/// Append-only change log for an employee (status/position/salary transitions).
model EmploymentHistory {
  id            String   @id @default(uuid()) @db.Uuid
  employeeId    String   @db.Uuid
  changeType    String
  fromValue     Json?
  toValue       Json?
  effectiveDate DateTime @db.Date
  note          String?
  createdBy     String?  @db.Uuid
  createdAt     DateTime @default(now())

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employment_history")
}

/// A stored 512-d ArcFace embedding for an enrolled face. Multiple per employee (frames).
model FaceEmbedding {
  id             String   @id @default(uuid()) @db.Uuid
  employeeId     String   @db.Uuid
  /// L2-normalized 512-float embedding. Cosine similarity done in-service (no pgvector).
  vector         Float[]
  quality        Float    @default(0)
  sourcePhotoUrl String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([active])
  @@map("face_embeddings")
}

/// One row per employee per working day (idempotent). Check-in/out each stamp a photo,
/// a face-match score, and derive lateMinutes / workingMinutes / status.
model Attendance {
  id               String           @id @default(uuid()) @db.Uuid
  employeeId       String           @db.Uuid
  depotId          String           @db.Uuid
  workDate         DateTime         @db.Date
  checkInAt        DateTime?
  checkOutAt       DateTime?
  checkInPhotoUrl  String?
  checkOutPhotoUrl String?
  checkInScore     Float?
  checkOutScore    Float?
  lateMinutes      Int              @default(0)
  workingMinutes   Int?
  status           AttendanceStatus @default(ABSENT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  employee         Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  adjustments      AttendanceAdjustment[]

  @@unique([employeeId, workDate])
  @@index([depotId, workDate])
  @@index([workDate])
  @@map("attendance")
}

/// A manual correction to an attendance row (HR override), kept for audit.
model AttendanceAdjustment {
  id           String     @id @default(uuid()) @db.Uuid
  attendanceId String     @db.Uuid
  reason       String
  before       Json?
  after        Json?
  approvedBy   String?    @db.Uuid
  createdAt    DateTime   @default(now())

  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@map("attendance_adjustments")
}

/// Work shift definition (future-ready; MVP uses the config default 08:00 start).
model Shift {
  id        String   @id @default(uuid()) @db.Uuid
  depotId   String?  @db.Uuid
  name      String
  startTime String
  endTime   String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([depotId])
  @@map("shifts")
}

/// Non-working day. depotId null = network-wide (national) holiday.
model Holiday {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @db.Date
  name      String
  depotId   String?  @db.Uuid
  createdAt DateTime @default(now())

  @@unique([date, depotId])
  @@index([date])
  @@map("holidays")
}

/// A month's payroll for one employee (idempotent per period).
model Payroll {
  id              String        @id @default(uuid()) @db.Uuid
  employeeId      String        @db.Uuid
  /// "YYYY-MM".
  periodMonth     String
  status          PayrollStatus @default(DRAFT)
  gross           Decimal       @default(0) @db.Decimal(12, 2)
  totalBonus      Decimal       @default(0) @db.Decimal(12, 2)
  totalDeduction  Decimal       @default(0) @db.Decimal(12, 2)
  net             Decimal       @default(0) @db.Decimal(12, 2)
  presentDays     Int           @default(0)
  approvedBy      String?       @db.Uuid
  approvedAt      DateTime?
  paidAt          DateTime?
  createdBy       String?       @db.Uuid
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items           PayrollItem[]

  @@unique([employeeId, periodMonth])
  @@index([periodMonth, status])
  @@map("payrolls")
}

/// A signed payslip line (see PayrollItemKind).
model PayrollItem {
  id        String          @id @default(uuid()) @db.Uuid
  payrollId String          @db.Uuid
  kind      PayrollItemKind
  label     String
  amount    Decimal         @db.Decimal(12, 2)
  sourceRef String?
  createdAt DateTime        @default(now())

  payroll   Payroll         @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
  @@map("payroll_items")
}

model Bonus {
  id          String    @id @default(uuid()) @db.Uuid
  employeeId  String    @db.Uuid
  type        BonusType
  amount      Decimal   @db.Decimal(12, 2)
  /// "YYYY-MM" the bonus applies to.
  periodMonth String
  note        String?
  createdBy   String?   @db.Uuid
  createdAt   DateTime  @default(now())

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, periodMonth])
  @@map("bonuses")
}

model Deduction {
  id          String        @id @default(uuid()) @db.Uuid
  employeeId  String        @db.Uuid
  type        DeductionType
  amount      Decimal       @db.Decimal(12, 2)
  periodMonth String
  note        String?
  createdBy   String?       @db.Uuid
  createdAt   DateTime      @default(now())

  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, periodMonth])
  @@map("deductions")
}

model PerformanceReview {
  id          String   @id @default(uuid()) @db.Uuid
  employeeId  String   @db.Uuid
  periodMonth String
  score       Decimal  @db.Decimal(5, 2)
  metrics     Json     @default("{}")
  reviewerId  String?  @db.Uuid
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, periodMonth])
  @@index([employeeId])
  @@map("performance_reviews")
}

/// HR audit trail: who changed what. Written by an interceptor on every mutation.
model AuditLog {
  id       String   @id @default(uuid()) @db.Uuid
  actorId  String?  @db.Uuid
  action   String
  entity   String
  entityId String?
  before   Json?
  after    Json?
  ip       String?
  at       DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
  @@index([at])
  @@map("audit_logs")
}

/// Business-tunable settings (SalaryConfiguration): GLOBAL default + optional per-DEPOT
/// override. Same shape as the other services' service_settings table.
model ServiceSetting {
  id        String   @id @default(uuid()) @db.Uuid
  scope     String
  depotId   String?  @db.Uuid
  key       String
  value     String
  updatedBy String?  @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope, depotId])
  @@map("service_settings")
}
