// Hydromart promo-service data model (PRD Module 12 Promotions: FR-089 Coupon,
// FR-090 Voucher; BR-015 no voucher stacking — enforced by the caller at checkout,
// this service quotes/redeems a single voucher per order). Money is integer rupiah.
// Redemption is idempotent per order and increments a denormalised global usedCount.

generator client {
  provider = "prisma-client-js"
  // Service-local output so it never clobbers other services' @prisma/client.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("PROMO_DATABASE_URL")
}

/// How a voucher's `value` is interpreted (FR-089/FR-090).
enum DiscountType {
  PERCENTAGE
  FIXED
}

/// A discount voucher/coupon. `code` is stored UPPERCASE and unique.
model Voucher {
  id          String       @id @default(uuid())
  code        String       @unique
  description String?
  discountType DiscountType
  /// PERCENTAGE: a percent 1..100. FIXED: rupiah off.
  value       Int
  /// Minimum order subtotal (rupiah) required to use the voucher.
  minSpend    Int          @default(0)
  /// Cap on the discount for PERCENTAGE vouchers (rupiah); null = uncapped.
  maxDiscount Int?
  /// Total discount budget (rupiah) this voucher may burn across all redemptions;
  /// null = unlimited. Once cumulative discountApplied reaches it, the voucher stops.
  budgetCap   Int?
  validFrom   DateTime?
  validUntil  DateTime?
  /// Global redemption cap; null = unlimited.
  usageLimit  Int?
  /// Per-customer redemption cap.
  perCustomerLimit Int     @default(1)
  /// Denormalised global redemption count (kept in step with redemptions).
  usedCount   Int          @default(0)
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  redemptions VoucherRedemption[]
  grants      VoucherGrant[]

  @@map("vouchers")
}

/// A voucher granted to a specific customer's wallet (spec 5h "voucher baru"). The
/// voucher itself stays code-based/usable per its own rules; a grant is the record that
/// this customer was given it — unique per (voucher, customer) so notifications fire once.
model VoucherGrant {
  id         String   @id @default(uuid())
  voucher    Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  voucherId  String
  customerId String
  createdAt  DateTime @default(now())

  @@unique([voucherId, customerId])
  @@index([customerId])
  @@map("voucher_grants")
}

/// A depot→HQ request to create a voucher (design 14b). A depot manager proposes the
/// voucher fields; HQ approves (which creates the real Voucher and stores its id here)
/// or rejects. Denormalises depotName for the queue display.
model VoucherRequest {
  id               String       @id @default(uuid())
  depotId          String
  depotName        String
  code             String
  description      String?
  discountType     DiscountType
  value            Int
  minSpend         Int          @default(0)
  maxDiscount      Int?
  usageLimit       Int?
  perCustomerLimit Int          @default(1)
  note             String?
  status           String       @default("PENDING")
  requestedBy      String
  decidedBy        String?
  /// The voucher created on approval; null while pending/rejected.
  createdVoucherId String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([status, createdAt])
  @@map("voucher_requests")
}

/// A marketing banner shown on the customer Home page (distinct from Voucher, a
/// discount rule). `voucherCode` optionally links a banner to a voucher to apply.
model Promotion {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  subtitle    String?
  imageUrl    String?
  ctaLabel    String?
  ctaHref     String?
  voucherCode String?
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([active])
  @@map("promotions")
}

/// One row per voucher redemption. Unique per order makes redeem idempotent.
model VoucherRedemption {
  id              String   @id @default(uuid())
  voucher         Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  voucherId       String
  voucherCode     String
  customerId      String
  orderId         String
  discountApplied Int
  createdAt       DateTime @default(now())

  @@unique([orderId])
  @@index([voucherId, customerId])
  @@map("voucher_redemptions")
}
