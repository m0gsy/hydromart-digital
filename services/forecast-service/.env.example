NODE_ENV=development
FORECAST_SERVICE_PORT=3014
FORECAST_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_forecast?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
# Default recency window (days) for churn risk banding; the churn query `days` param overrides it.
CHURN_WINDOW_DAYS=45
# order-service base URL; used later for the completed-orders rebuild feed (fail-open when blank).
ORDER_SERVICE_URL=
# depot-service base URL; resolves a franchise owner's depots for the forecast ownership check
# (fail-CLOSED: a FRANCHISE_OWNER forecast call returns 503 when blank). Other roles unaffected.
DEPOT_SERVICE_URL=
