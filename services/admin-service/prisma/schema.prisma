// Hydromart admin-service data model (platform administration).
//
// Two tables, both owned by SUPER_ADMIN:
//   * feature_flags  (Design 8b) — network feature rollout switches. `key` is the stable
//     identifier the app/backends read; `state` drives who sees the feature. `rolloutPct`
//     is advisory metadata for a ROLLOUT-state flag (percentage ramp).
//   * system_settings (Design 8b platform config) — a SINGLETON row of global defaults
//     (timezone, currency, service radius). Exactly one row (id = "singleton").
//
// The aggregate system-health endpoint (Design 13b) has NO table — it fans out to each
// peer service's /health at request time.

generator client {
  provider = "prisma-client-js"
  // Service-local output so it never clobbers other services' @prisma/client.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("ADMIN_DATABASE_URL")
}

/// Feature-flag lifecycle. ROLLOUT = gated ramp (see rolloutPct); ACTIVE = fully on;
/// BETA = opt-in / limited audience; OFF = disabled.
enum FlagState {
  ROLLOUT
  ACTIVE
  BETA
  OFF
}

/// A single network-wide feature switch (Design 8b). `key` is machine-readable and unique.
model FeatureFlag {
  id          String    @id @default(uuid())
  key         String    @unique
  label       String
  description String
  state       FlagState @default(OFF)
  /// Percentage ramp (0..100) for a ROLLOUT-state flag; null when not ramping.
  rolloutPct  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("feature_flags")
}

/// Global platform defaults (Design 8b). Singleton: exactly one row, id = "singleton".
model SystemSetting {
  id              String   @id @default(uuid())
  /// Default IANA timezone for the network (e.g. "Asia/Jakarta").
  defaultTimezone String   @default("Asia/Jakarta")
  /// ISO-4217 currency code presented across the platform (e.g. "IDR").
  currency        String   @default("IDR")
  /// Default depot service radius in kilometres.
  serviceRadiusKm Int      @default(5)
  updatedAt       DateTime @updatedAt

  @@map("system_settings")
}

// ---------------------------------------------------------------------------
// Integration & governance (0002_admin_integration): API keys (13d), webhook
// endpoints (19c), data-export logs (13c), scheduled reports (15c). SUPER_ADMIN /
// HEAD_OFFICE gated. All additive — 0001_init is untouched.
// ---------------------------------------------------------------------------

/// Deployment target a credential/report belongs to.
enum ApiKeyEnvironment {
  PROD
  STAGING
}

/// Serialized output format for exports and scheduled reports.
enum ExportFormat {
  XLSX
  CSV
  PDF
}

/// Lifecycle of a data-export job.
enum ExportStatus {
  PENDING
  DONE
  FAILED
}

/// Recurrence of a scheduled report.
enum ReportCadence {
  DAILY
  WEEKLY
  MONTHLY
}

/// A service API credential (Design 13d). The full secret is shown ONCE at creation;
/// only `keyPrefix` (safe to display) and `keyHash` (sha256, for verification) persist.
model ApiKey {
  id          String            @id @default(uuid())
  name        String
  /// Display-safe leading segment, e.g. "hm_live_a1b2c3d4".
  keyPrefix   String
  /// sha256 of the full secret; the secret itself is never stored.
  keyHash     String
  scopes      String[]
  environment ApiKeyEnvironment @default(PROD)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime          @default(now())

  @@map("api_keys")
}

/// An outbound webhook subscription (Design 19c). `deliveryRatePct`/`lastDeliveryStatus`
/// are updated by future delivery attempts; null until a real delivery has been recorded.
model WebhookEndpoint {
  id                 String   @id @default(uuid())
  url                String
  events             String[]
  active             Boolean  @default(true)
  secret             String?
  /// Outcome of the most recent delivery attempt (null until one occurs).
  lastDeliveryStatus String?
  /// Rolling success rate 0..100 (null until real deliveries are recorded).
  deliveryRatePct    Int?
  createdAt          DateTime @default(now())

  @@map("webhook_endpoints")
}

/// An immutable data-export audit entry (Design 13c). Written by export jobs via the
/// internal-key ingest endpoint; read (paginated, newest-first) by HQ.
model ExportLog {
  id               String       @id @default(uuid())
  dataset          String
  requestedById    String?
  requestedByEmail String
  format           ExportFormat
  rowCount         Int?
  status           ExportStatus @default(PENDING)
  createdAt        DateTime     @default(now())

  @@index([dataset])
  @@index([status])
  @@map("export_logs")
}

/// A recurring report definition (Design 15c). `nextRunAt` is advisory metadata for the
/// future scheduler; toggling `enabled` pauses it without deleting.
model ScheduledReport {
  id         String        @id @default(uuid())
  name       String
  cadence    ReportCadence
  recipients String[]
  format     ExportFormat  @default(XLSX)
  nextRunAt  DateTime?
  enabled    Boolean       @default(true)
  createdAt  DateTime      @default(now())

  @@map("scheduled_reports")
}
