NODE_ENV=development
ADMIN_SERVICE_PORT=3017
ADMIN_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_admin?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
# Peer service base URLs probed by the aggregate system-health endpoint (13b, FR-13b).
# Each is OPTIONAL: an unset URL is omitted from the roll-up rather than failing boot.
# In docker these resolve to the internal service hostnames (see docker-compose.prod.yml).
AUTH_SERVICE_URL=http://localhost:3001
CUSTOMER_SERVICE_URL=http://localhost:3002
PRODUCT_SERVICE_URL=http://localhost:3003
ORDER_SERVICE_URL=http://localhost:3004
PAYMENT_SERVICE_URL=http://localhost:3005
DELIVERY_SERVICE_URL=http://localhost:3006
DEPOT_SERVICE_URL=http://localhost:3007
DASHBOARD_SERVICE_URL=http://localhost:3008
LOYALTY_SERVICE_URL=http://localhost:3009
PROMO_SERVICE_URL=http://localhost:3010
REFERRAL_SERVICE_URL=http://localhost:3011
CRM_SERVICE_URL=http://localhost:3012
RECOMMENDATION_SERVICE_URL=http://localhost:3013
FORECAST_SERVICE_URL=http://localhost:3014
PAYOUT_SERVICE_URL=http://localhost:3016
