NODE_ENV=development
LOYALTY_SERVICE_PORT=3009
LOYALTY_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_loyalty?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
# Loyalty policy (BR-013/BR-014). 1 point per this many rupiah of order subtotal.
LOYALTY_EARN_RATE_RUPIAH=1000
# Points expire this many months after they are earned.
LOYALTY_POINT_EXPIRY_MONTHS=12
# customer-service base URL, used to resolve a depot's customers for the
# depot-scoped loyalty summary. Blank = no directory → depot summary returns zeros.
CUSTOMER_SERVICE_URL=http://localhost:3002
