# auth-service specific env (see repository-root .env.example for the full list).
NODE_ENV=development
AUTH_SERVICE_PORT=3001
AUTH_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_auth?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_DELIVERY_CHANNEL=console
OTP_PEPPER=change-me-otp-pepper
WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_OTP_TEMPLATE=hydromart_otp
SMS_API_BASE_URL=
SMS_API_TOKEN=
SMS_SENDER_ID=HYDROMART
GOOGLE_OAUTH_CLIENT_ID=
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
