NODE_ENV=development
REFERRAL_SERVICE_PORT=3011
REFERRAL_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_referral?schema=public
# Must match auth-service JWT_ACCESS_SECRET (verifies its access tokens).
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
# loyalty-service base URL; referral qualification awards points there (fail-open).
LOYALTY_SERVICE_URL=http://localhost:3009
# Points granted to the referrer when a referral qualifies (FR-092).
REFERRAL_REFERRER_POINTS=500
# Welcome-bonus points granted to the referee when a referral qualifies (FR-092).
REFERRAL_REFEREE_POINTS=250
