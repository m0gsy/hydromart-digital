NODE_ENV=development
REFERRAL_SERVICE_PORT=3011
REFERRAL_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_referral?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
# loyalty-service base URL; referral qualification awards points there (fail-open).
LOYALTY_SERVICE_URL=http://localhost:3009
# customer-service base URL; depot referral aggregate resolves depot->customerIds there.
# Blank = directory lookup disabled (aggregate degrades to zeros, fail-open).
CUSTOMER_SERVICE_URL=http://localhost:3002
# Points granted to the referrer when a referral qualifies (FR-092).
REFERRAL_REFERRER_POINTS=500
# Welcome-bonus points granted to the referee when a referral qualifies (FR-092).
REFERRAL_REFEREE_POINTS=250
