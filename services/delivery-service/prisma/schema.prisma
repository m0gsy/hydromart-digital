// Hydromart delivery-service data model (PRD Module 4, Delivery & Proof of Delivery).
// Owns the driver assignment for an order and its proof of delivery. Linked to an
// order by orderId only; the order lifecycle itself stays owned by order-service,
// which this service advances over HTTP as the delivery progresses (BR-012).

generator client {
  provider = "prisma-client-js"
  // Service-local output so it never clobbers other services' @prisma/client.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DELIVERY_DATABASE_URL")
}

// Driver-facing slice of the order lifecycle. ASSIGNED → PICKED_UP → ON_DELIVERY
// → DELIVERED; FAILED is reachable from any active state.
enum DeliveryStatus {
  ASSIGNED
  PICKED_UP
  ON_DELIVERY
  DELIVERED
  FAILED
  RESCHEDULED
}

/// How a courier tried to reach the customer before declaring a no-show (design 5a).
enum ContactMethod {
  CALL
  WHATSAPP
}

/// A courier's availability while on shift. ENDED is terminal (checked out).
/// Only ONLINE accepts new assignments.
enum ShiftStatus {
  ONLINE
  BREAK
  OFFLINE
  ENDED
}

/// Lifecycle of a courier's end-of-shift COD deposit (design 2d). SUBMITTED once
/// the courier hands cash to the cashier; the cashier then VERIFIED or DISPUTED it.
enum SettlementStatus {
  SUBMITTED
  VERIFIED
  DISPUTED
}

/// What a courier reports from the field (design 4b).
enum IncidentCategory {
  ACCIDENT
  VEHICLE_BREAKDOWN
  THEFT_OR_THREAT
  CUSTOMER_DISPUTE
  PRODUCT_DAMAGE
  OTHER
}

/// HIGH incidents are pushed to the ops feed; all are stored.
enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
}

/// One courier work session at one depot, opened by a GPS-verified check-in at the
/// depot and closed by check-out. It is the window every end-of-shift COD
/// settlement is computed over, and the gate on receiving assignments.
model Shift {
  id       String      @id @default(uuid()) @db.Uuid
  driverId String      @db.Uuid
  depotId  String      @db.Uuid
  status   ShiftStatus @default(ONLINE)

  checkInAt  DateTime @default(now())
  checkInLat Float
  checkInLng Float
  /// checkInAt + SHIFT_LENGTH_HOURS, frozen at check-in so a config change cannot
  /// move a running shift's end. ponytail: derived, not rostered — a real roster
  /// (design Operator 6d / Manager 7b) would set this ahead of time instead.
  expectedEndAt DateTime

  checkOutAt  DateTime?
  checkOutLat Float?
  checkOutLng Float?

  /// Break time consumed so far, accumulated on each BREAK → ONLINE/OFFLINE exit.
  /// Quota is config (SHIFT_BREAK_QUOTA_MINUTES); exceeding it is recorded, not
  /// blocked — the overage becomes a payout DEDUCTION, not a failed request.
  breakSecondsUsed Int       @default(0)
  breakStartedAt   DateTime?

  @@index([driverId, checkInAt])
  @@index([depotId, status])
  @@map("shifts")
}

/// One driver assignment per order (orderId unique). Destination is snapshotted
/// at assignment so the driver app can navigate without a cross-service call.
model Delivery {
  id          String         @id @default(uuid()) @db.Uuid
  orderId     String         @unique @db.Uuid
  orderNumber String
  driverId    String         @db.Uuid
  // Depot the order was routed to, snapshotted at assignment. Nullable: legacy
  // deliveries + assignments made without a known depot are excluded from
  // depot-scoped SLA (franchise dashboard). See dashboard-service franchise BFF.
  depotId     String?        @db.Uuid
  status      DeliveryStatus @default(ASSIGNED)

  destinationAddress String
  destinationLat     Float?
  destinationLng     Float?

  // Snapshotted at assignment so the courier delivery-detail (design 4a) renders
  // recipient contact + the order manifest + COD without a live cross-service call.
  // recipientPhone is the CUSTOMER's number (courier → customer). items is a
  // [{name, qty}] line-item snapshot. codAmount is whole-IDR cash to collect;
  // null = non-COD / unknown (legacy rows, or payment method not yet joined).
  recipientPhone String?
  items          Json?
  codAmount      Int?

  // Latest reported driver position (live tracking, PRD 10a). Overwritten on each
  // ping while en route; no history kept (MVP — "where is the driver now").
  lastLat        Float?
  lastLng        Float?
  lastLocationAt DateTime?

  // Customer-facing ETA, computed at ON_DELIVERY start from straight-line distance
  // ÷ an assumed urban speed and pushed onto the order payload. Null = not yet
  // started / uncomputable (no destination or origin coords).
  estimatedArrivalAt DateTime?

  assignedAt    DateTime  @default(now())
  pickedUpAt    DateTime?
  startedAt     DateTime?
  deliveredAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  // Reschedule (design 3c): the new target time/slot the courier agreed with the
  // customer + an optional note. Set when status becomes RESCHEDULED.
  rescheduledFor DateTime?
  rescheduleSlot String?
  rescheduleNote String?

  proof           ProofOfDelivery?
  history         DeliveryStatusHistory[]
  contactAttempts ContactAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([driverId])
  @@index([status])
  @@index([depotId])
  // Every SLA aggregate filters on deliveredAt (+ depot scope); back it (audit DB-4).
  @@index([deliveredAt])
  @@index([depotId, deliveredAt])
  @@map("deliveries")
}

/// A courier's end-of-shift cash-on-delivery deposit (design 2d/9a). Computed over
/// exactly one ended shift: expectedAmount is snapshotted from payment-service at
/// submit time (source of truth for "how much"), so a later refund cannot silently
/// move the debt the courier settled against. The cashier verifies or disputes it.
model CashSettlement {
  id       String           @id @default(uuid()) @db.Uuid
  shiftId  String           @unique @db.Uuid
  driverId String           @db.Uuid
  depotId  String           @db.Uuid
  status   SettlementStatus @default(SUBMITTED)

  /// COD orders counted in this settlement (DELIVERED within the shift window).
  orderIds String[] @db.Uuid
  /// Snapshot of the PAID cash total over orderIds at submit time (whole IDR).
  expectedAmount  Int
  /// Cash the courier actually handed the cashier (whole IDR).
  depositedAmount Int
  /// depositedAmount - expectedAmount. Negative = shortfall (courier owes).
  variance Int
  /// The cashier's call on a shortfall: whether it is charged to the courier
  /// (pushed to payout as CASH_VARIANCE in slice 13). Only meaningful once VERIFIED.
  chargedToDriver Boolean @default(false)
  note            String?

  verifiedBy String?   @db.Uuid
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([depotId, status])
  @@index([driverId, createdAt])
  @@map("cash_settlements")
}

/// Mandatory proof captured at completion: photo, GPS, timestamp, signature
/// (BR: proof of delivery mandatory). Exactly one per delivery.
model ProofOfDelivery {
  id            String   @id @default(uuid()) @db.Uuid
  deliveryId    String   @unique @db.Uuid
  delivery      Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  photoUrl      String
  signatureUrl  String
  recipientName String
  latitude      Float
  longitude     Float
  note          String?
  capturedAt    DateTime @default(now())

  @@map("proofs_of_delivery")
}

/// One recorded attempt by the courier to reach the customer (design 5a). The
/// count + first attempt time gate whether a no-show may be declared.
model ContactAttempt {
  id         String        @id @default(uuid()) @db.Uuid
  deliveryId String        @db.Uuid
  delivery   Delivery      @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  driverId   String        @db.Uuid
  method     ContactMethod @default(CALL)
  note       String?
  createdAt  DateTime      @default(now())

  @@index([deliveryId])
  @@map("contact_attempts")
}

/// A courier-reported field incident (design 4b). Optionally tied to a delivery;
/// depotId is snapshotted so ops can scope. Photo (optional) goes through the
/// existing PoD upload endpoint, so only the URL is stored here.
model FieldIncident {
  id          String           @id @default(uuid()) @db.Uuid
  driverId    String           @db.Uuid
  deliveryId  String?          @db.Uuid
  depotId     String?          @db.Uuid
  category    IncidentCategory
  severity    IncidentSeverity
  description String
  photoUrl    String?
  lat         Float?
  lng         Float?
  createdAt   DateTime         @default(now())

  @@index([driverId, createdAt])
  @@index([depotId, createdAt])
  @@map("field_incidents")
}

/// Append-only audit of every delivery status transition.
model DeliveryStatusHistory {
  id         String         @id @default(uuid()) @db.Uuid
  deliveryId String         @db.Uuid
  delivery   Delivery       @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  status     DeliveryStatus
  changedBy  String?        @db.Uuid
  note       String?
  createdAt  DateTime       @default(now())

  @@index([deliveryId])
  @@map("delivery_status_history")
}
