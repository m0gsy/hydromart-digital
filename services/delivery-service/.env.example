NODE_ENV=development
DELIVERY_SERVICE_PORT=3006
DELIVERY_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_delivery?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
# order-service base URL — delivery status changes are synced to the order (BR-012).
ORDER_SERVICE_URL=http://localhost:3004
# depot-service base URL — read for the depot's coordinates when a courier checks in.
DEPOT_SERVICE_URL=http://localhost:3007
# crm-service base URL + ops WhatsApp number for pushing HIGH field incidents (4b) to
# the ops feed. Both blank = incident ops alerting disabled (fail-open).
CRM_SERVICE_URL=http://localhost:3012
OPS_ALERT_PHONE=
# Max concurrent active deliveries per driver (BR: one driver = one active order; raise for multi-drop).
MAX_ACTIVE_DELIVERIES_PER_DRIVER=1
# How close to the depot a courier must stand to check in, in metres.
SHIFT_CHECKIN_RADIUS_M=200
# Shift window length, frozen onto the shift at check-in.
SHIFT_LENGTH_HOURS=8
# Paid break allowance per shift. Going over is recorded as an overage, not blocked.
SHIFT_BREAK_QUOTA_MINUTES=30
# No-show gate (5a): min contact attempts + min wait (seconds from first attempt)
# before a delivery may be failed as a no-show.
NO_SHOW_MIN_CONTACT_ATTEMPTS=2
NO_SHOW_MIN_WAIT_SECONDS=300
# On-time threshold (minutes from assignment to delivery) for the SLA report.
DELIVERY_SLA_MINUTES=120
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
