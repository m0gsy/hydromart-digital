NODE_ENV=development
DELIVERY_SERVICE_PORT=3006
DELIVERY_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_delivery?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
# order-service base URL — delivery status changes are synced to the order (BR-012).
ORDER_SERVICE_URL=http://localhost:3004
# Max concurrent active deliveries per driver (BR: one driver = one active order; raise for multi-drop).
MAX_ACTIVE_DELIVERIES_PER_DRIVER=1
# On-time threshold (minutes from assignment to delivery) for the SLA report.
DELIVERY_SLA_MINUTES=120
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
