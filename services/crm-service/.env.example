NODE_ENV=development
CRM_SERVICE_PORT=3012
CRM_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_crm?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
# WhatsApp Cloud API base URL + bearer token for broadcasts (FR-094).
# Leave WHATSAPP_API_URL blank to run the broadcast adapter in console/dev mode.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
# customer-service base URL for FR-087 attribute segmentation. Blank disables segment targeting.
CUSTOMER_SERVICE_URL=http://localhost:3002
