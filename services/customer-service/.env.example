NODE_ENV=development
CUSTOMER_SERVICE_PORT=3002
CUSTOMER_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_customer?schema=public
# JWT_ACCESS_SECRET & INTERNAL_SERVICE_KEY are shared across every service.
# Set them ONCE in the repo-root .env (each service loads it via the ../../.env
# fallback in ConfigModule). Do NOT redefine them here — divergent copies are
# exactly what broke cross-service auth before (see hydromart-prod-boot-findings).
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100
MAX_ADDRESSES_PER_CUSTOMER=20
# Birthday promo (FR-091). Blank LOYALTY_SERVICE_URL disables the sweep.
LOYALTY_SERVICE_URL=http://localhost:3009
BIRTHDAY_REWARD_POINTS=250
