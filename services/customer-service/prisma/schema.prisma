// Hydromart customer-service data model (PRD Module 2).
// Owns customer profile extension, delivery addresses, and notification prefs.
// Keyed by customerId — the identity id issued by auth-service.

generator client {
  provider = "prisma-client-js"
  // Custom output so this service's client does not clobber other services'
  // clients in the hoisted node_modules/@prisma/client.
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("CUSTOMER_DATABASE_URL")
}

enum MembershipTier {
  BASIC
  SILVER
  GOLD
}

/// Mirrors payment-service's PaymentMethod enum (duplicated per-service, as with
/// MembershipTier). Type of a saved, reusable payment instrument.
enum SavedPaymentType {
  CASH
  TRANSFER
  QRIS
  EWALLET
  VA
}

/// Profile extension for a customer. One row per identity, lazily created.
model CustomerProfile {
  customerId     String         @id @db.Uuid
  membershipTier MembershipTier @default(BASIC)
  pointBalance   Int            @default(0)
  favoriteDepotId String?       @db.Uuid
  /// Date of birth (day precision) — drives the birthday promo (FR-091). Optional.
  birthdate      DateTime?      @db.Date
  /// Year of the last birthday reward grant; makes the sweep idempotent (one grant per year).
  lastBirthdayRewardYear Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("customer_profiles")
}

/// A delivery address. BR-004: max 20 per customer. Exactly one is primary.
model Address {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @db.Uuid
  label         String
  recipientName String
  phone         String
  addressLine   String
  city          String
  province      String
  postalCode    String?
  latitude      Float?
  longitude     Float?
  // Free-text landmark / patokan the customer adds ("pagar hijau sebelah warung Bu Ani").
  // Optional; flows to the courier via the per-order note at checkout.
  notes         String?
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  // Audit DB-2: a partial UNIQUE index enforcing one primary per customer is added by
  // migration 20260718141000_one_primary_address (Prisma can't express a partial
  // unique index here). Pairs with the transactional AddressRepository.setPrimaryExclusive.
  @@map("addresses")
}

/// A saved, reusable payment instrument (spec 4f Account → Metode pembayaran).
/// Management-only — checkout still selects a per-transaction method. Exactly one
/// default per customer; the first saved becomes the default.
model SavedPaymentMethod {
  id               String           @id @default(uuid()) @db.Uuid
  customerId       String           @db.Uuid
  type             SavedPaymentType
  /// Display label, e.g. "Cash on delivery" / "GoPay".
  label            String
  /// Masked instrument tail, e.g. "••••4821"; null for cash.
  maskedIdentifier String?
  isDefault        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([customerId])
  // Audit (DB-2 pattern): a partial UNIQUE index enforcing one default per customer is
  // added by migration 20260718150000_one_default_payment_method (Prisma can't express a
  // partial unique index here). Pairs with PaymentMethodRepository.setDefaultExclusive.
  @@map("saved_payment_methods")
}

/// A favorited (wishlisted) product. One row per (customer, product). Scoped to the
/// caller's customerId; productId references a product owned by another service.
model Favorite {
  id         String   @id @default(uuid())
  customerId String
  productId  String
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("favorites")
}

/// Per-customer notification channel preferences (PRD §27).
model NotificationPreference {
  customerId String   @id @db.Uuid
  push       Boolean  @default(true)
  email      Boolean  @default(true)
  whatsapp   Boolean  @default(true)
  /// Per-app fine-grained category mutes (design 7b courier toggles). Keyed map of
  /// category id → enabled, e.g. { "tasks": true, "promo": false }. Empty = all on.
  categories Json     @default("{}")
  updatedAt  DateTime @updatedAt

  @@map("notification_preferences")
}
