# ------------------------------------------------------------------
# Hydromart — PRODUCTION secrets & tunables for the Docker Compose deploy.
#
#   cp .env.production.example .env      # docker compose auto-loads ./.env
#   # then fill in every value marked REQUIRED below.
#
# NEVER commit the real .env. All REQUIRED values are read by
# docker-compose.prod.yml via ${VAR:?...} and the deploy will refuse to
# start if any are unset.
#
# Generate a strong random secret with:
#   openssl rand -hex 32
# (hex-32 = 64 chars, comfortably above every minimum-length requirement).
# ------------------------------------------------------------------

# ---- REQUIRED: database ----
# Password for the `hydromart` Postgres superuser. Used both by the postgres
# container and inside every service's <SVC>_DATABASE_URL.
POSTGRES_PASSWORD=

# ---- REQUIRED: auth / JWT ----
# Access token signing secret (min 32 chars). openssl rand -hex 32
JWT_ACCESS_SECRET=
# Refresh token signing secret (min 32 chars, different from the access one).
JWT_REFRESH_SECRET=

# ---- REQUIRED: internal service-to-service auth ----
# Shared key every service uses to authenticate internal calls (notifications,
# payment->order confirm). Must be identical across all services (it is — one var).
INTERNAL_SERVICE_KEY=

# ---- REQUIRED: payment webhook ----
# HMAC-SHA256 secret the payment gateway signs webhook callbacks with (min 16 chars).
PAYMENT_WEBHOOK_SECRET=

# ---- REQUIRED: OTP ----
# Server-side pepper mixed into OTP hashing. openssl rand -hex 32
OTP_PEPPER=

# ---- REQUIRED: web app (baked into the client bundle at build time) ----
# The PUBLIC URL visitors' browsers use to reach the API gateway — NOT an internal
# docker hostname. It is frozen into the JS bundle at `docker compose build`, so
# set it correctly BEFORE building (changing it later needs a rebuild). Use your
# real domain behind TLS (https://api.your-domain.com) or, for a bare-IP deploy,
# http://<your-vps-public-ip>:8080. The build FAILS if this is unset.
PUBLIC_API_URL=
# Google Sign-In web client id. Blank hides the "Continue with Google" button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ---- OPTIONAL: payment gateway (online charges) ----
# Blank = online charges fail closed (COD / manual confirm still work).
PAYMENT_GATEWAY_BASE_URL=
PAYMENT_GATEWAY_API_KEY=

# ---- OPTIONAL: WhatsApp (CRM broadcasts + depot low-stock alerts) ----
# Blank = console/log fallback, no real messages are sent.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
# Ops/warehouse WhatsApp number for depot low-stock alerts. Blank = disabled.
DEPOT_ALERT_PHONE=
