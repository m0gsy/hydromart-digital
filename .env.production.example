# ------------------------------------------------------------------
# Hydromart — PRODUCTION secrets & tunables for the Docker Compose deploy.
#
#   cp .env.production.example .env      # docker compose auto-loads ./.env
#   # then fill in every value marked REQUIRED below.
#
# NEVER commit the real .env. All REQUIRED values are read by
# docker-compose.prod.yml via ${VAR:?...} and the deploy will refuse to
# start if any are unset.
#
# Generate ALL secret values at once with:
#   bash scripts/generate-secrets.sh
# (or one at a time: openssl rand -hex 32 — 64 chars, above every minimum).
# Services boot-fail in production if any secret is missing OR still a
# "change-me" dev placeholder (packages/platform requiredSecret guard).
# ------------------------------------------------------------------

# ---- REQUIRED: database ----
# Password for the `hydromart` Postgres superuser. Used both by the postgres
# container and inside every service's <SVC>_DATABASE_URL.
POSTGRES_PASSWORD=

# ---- REQUIRED: auth / JWT ----
# Access token signing secret (min 32 chars). openssl rand -hex 32
JWT_ACCESS_SECRET=
# Refresh token signing secret (min 32 chars, different from the access one).
JWT_REFRESH_SECRET=

# ---- REQUIRED: internal service-to-service auth ----
# Shared key every service uses to authenticate internal calls (notifications,
# payment->order confirm). Must be identical across all services (it is — one var).
INTERNAL_SERVICE_KEY=

# ---- REQUIRED: payment webhook ----
# HMAC-SHA256 secret the payment gateway signs webhook callbacks with (min 16 chars).
PAYMENT_WEBHOOK_SECRET=

# ---- REQUIRED: OTP ----
# Server-side pepper mixed into OTP hashing. openssl rand -hex 32
OTP_PEPPER=

# Delivery channel: console | zenziva | sms. `console` ONLY writes the code to
# the auth container log, so real customers can never sign up — it is a
# development default. Set the real channel plus its credentials below before
# taking signups.
#
# zenziva — the provider in use. Userkey + API Key come from the Zenziva console's
# "HTTP API" panel; the sender mask is configured there, not here. Copy is in
# zenziva-otp-delivery.adapter.ts (separate per registration / login).
#
# sms — generic token-authenticated JSON gateway, kept for a future switch.
OTP_DELIVERY_CHANNEL=console
ZENZIVA_BASE_URL=https://console.zenziva.net
ZENZIVA_USERKEY=
ZENZIVA_PASSKEY=
SMS_API_BASE_URL=
SMS_API_TOKEN=
SMS_SENDER_ID=HYDROMART

# ---- REQUIRED: web app (baked into the client bundle at build time) ----
# The PUBLIC URL visitors' browsers use to reach the API gateway — NOT an internal
# docker hostname. It is frozen into the JS bundle at `docker compose build`, so
# set it correctly BEFORE building (changing it later needs a rebuild). Use your
# real domain behind TLS (https://api.your-domain.com) or, for a bare-IP deploy,
# http://<your-vps-public-ip>:8080. The build FAILS if this is unset.
PUBLIC_API_URL=
# Browser origin(s) allowed to call the gateway API (comma-separated, no trailing
# slash). MUST match where the web app is served or CORS blocks every fetch.
# With TLS: https://<WEB_DOMAIN>. Bare-IP: http://<your-vps-public-ip>:3000.
CORS_ALLOWED_ORIGINS=

# ---- OPTIONAL: TLS reverse proxy (only used with `--profile tls`) ----
# Public hostnames that resolve (DNS A/AAAA) to this VPS. Caddy auto-provisions
# Let's Encrypt certs for both. Leave blank if you are not running the tls profile.
# When you DO use TLS, set PUBLIC_API_URL above to https://<API_DOMAIN>.
WEB_DOMAIN=
API_DOMAIN=

# ---- REQUIRED: object storage (BiznetGio NEO / any S3-compatible) ----
# Shared endpoint/region/driver for every service that stores files. Per NEO's
# per-bucket keys, each service has its OWN bucket + access key below.
STORAGE_DRIVER=s3
STORAGE_S3_ENDPOINT=https://nos.jkt-1.neo.id
STORAGE_S3_REGION=jkt-1
# product images (product-service)
PRODUCT_STORAGE_S3_BUCKET=hydromart-products
PRODUCT_STORAGE_S3_ACCESS_KEY_ID=
PRODUCT_STORAGE_S3_SECRET_ACCESS_KEY=
PRODUCT_STORAGE_PUBLIC_BASE_URL=https://nos.jkt-1.neo.id/hydromart-products
# proof-of-delivery photos (delivery-service)
DELIVERY_STORAGE_S3_BUCKET=hydromart-pod
DELIVERY_STORAGE_S3_ACCESS_KEY_ID=
DELIVERY_STORAGE_S3_SECRET_ACCESS_KEY=
DELIVERY_STORAGE_PUBLIC_BASE_URL=https://nos.jkt-1.neo.id/hydromart-pod
# customer avatar photos (auth-service). Reuse the product bucket+creds if you
# prefer one bucket — avatars go under the avatars/ prefix, no collision.
AUTH_STORAGE_S3_BUCKET=hydromart-avatars
AUTH_STORAGE_S3_ACCESS_KEY_ID=
AUTH_STORAGE_S3_SECRET_ACCESS_KEY=
AUTH_STORAGE_PUBLIC_BASE_URL=https://nos.jkt-1.neo.id/hydromart-avatars

# ---- OPTIONAL: payment gateway (online charges) ----
# Blank = online charges fail closed (COD / manual confirm still work).
PAYMENT_GATEWAY_BASE_URL=
PAYMENT_GATEWAY_API_KEY=

# ---- OPTIONAL: error alerting ----
# Incoming webhook that receives a ping on every unhandled 5xx (route + stack).
# Works with Slack ("Incoming Webhooks") or Discord (channel webhook + `/slack`
# suffix, or plain — both payload keys are sent). Blank = disabled, no pings.
# Repeats of the same error are throttled (default 60s; tune ALERT_DEDUPE_SECONDS).
ALERT_WEBHOOK_URL=
# ALERT_DEDUPE_SECONDS=60

# ---- OPTIONAL: WhatsApp (CRM broadcasts + depot low-stock alerts) ----
# Blank = console/log fallback, no real messages are sent.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
# Ops/warehouse WhatsApp number for depot low-stock alerts. Blank = disabled.
DEPOT_ALERT_PHONE=
# Per-gallon deposit (IDR) refunded on a courier-recorded return (design 2e).
GALLON_DEPOSIT_IDR=20000

# ---- OPTIONAL: Web Push (browser notifications, design 7b) ----
# Blank = push disabled; the app still stores notifications + sends WhatsApp.
# Generate a keypair once with:  npm run gen:vapid
# Keep the PRIVATE key secret — never commit a filled-in .env.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@hydromart.id
