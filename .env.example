# ------------------------------------------------------------------
# Hydromart — environment variables (copy to .env and fill in values)
# NEVER commit a real .env file. Secrets belong in a secret manager.
# ------------------------------------------------------------------

# ---- Runtime ----
NODE_ENV=development

# ---- Customer Service ----
CUSTOMER_SERVICE_PORT=3002
CUSTOMER_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_customer?schema=public
MAX_ADDRESSES_PER_CUSTOMER=20
# Birthday promo (FR-091). Blank LOYALTY_SERVICE_URL disables the sweep; reuses loyalty-service.
LOYALTY_SERVICE_URL=http://localhost:3009
BIRTHDAY_REWARD_POINTS=250

# ---- Product Service ----
PRODUCT_SERVICE_PORT=3003
PRODUCT_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_product?schema=public

# ---- Order Service ----
ORDER_SERVICE_PORT=3004
ORDER_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_order?schema=public
# Base URL the order-service calls to resolve authoritative product prices at checkout.
PRODUCT_SERVICE_URL=http://localhost:3003
# depot-service base URL — checkout routes each order to the nearest covering depot (FR-098).
DEPOT_SERVICE_URL=http://localhost:3007
# loyalty-service base URL — points are awarded here when an order completes (BR-013).
LOYALTY_SERVICE_URL=http://localhost:3009
# promo-service base URL — vouchers are validated/redeemed here at checkout (FR-030/090).
PROMO_SERVICE_URL=http://localhost:3010
# referral-service base URL — referrals are qualified here when an order completes (FR-092).
REFERRAL_SERVICE_URL=http://localhost:3011
# crm-service base URL — WhatsApp notifications fire here on order lifecycle changes (FR-093/094).
CRM_SERVICE_URL=http://localhost:3012
# Shared secret for internal service-auth: authenticates notifications to crm AND the
# payment→order confirm callback. Must match INTERNAL_SERVICE_KEY everywhere. Blank = fail-closed.
INTERNAL_SERVICE_KEY=change-me-internal-service-key
# Flat delivery fee applied at checkout, in IDR (per-depot/zone pricing lands in M5).
ORDER_DELIVERY_FEE=5000

# ---- Payment Service ----
PAYMENT_SERVICE_PORT=3005
PAYMENT_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_payment?schema=public
# Payment gateway for online methods (QRIS/E-Wallet/VA). Blank in dev = online charges fail closed.
PAYMENT_GATEWAY_BASE_URL=
PAYMENT_GATEWAY_API_KEY=
# HMAC-SHA256 secret the gateway signs webhook callbacks with.
PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret-min-16-chars
# order-service base URL + shared secret: a settled payment (webhook/staff confirm) calls
# order-service to confirm the order (fires ORDER_CONFIRMED). Both blank = callback disabled.
ORDER_SERVICE_URL=http://localhost:3004
INTERNAL_SERVICE_KEY=change-me-internal-service-key

# ---- Delivery Service ----
DELIVERY_SERVICE_PORT=3006
DELIVERY_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_delivery?schema=public
# order-service base URL — delivery status changes are synced to the order (BR-012).
ORDER_SERVICE_URL=http://localhost:3004
# Max concurrent active deliveries per driver (BR: one driver = one active order; raise for multi-drop).
MAX_ACTIVE_DELIVERIES_PER_DRIVER=1
# Delivery SLA target in minutes (assigned→delivered); deliveries over this count as breached (FR-099).
DELIVERY_SLA_MINUTES=120

# ---- Dashboard Service (BFF, no database) ----
DASHBOARD_SERVICE_PORT=3008
# Upstream report sources the executive dashboard aggregates (FR-100).
ORDER_SERVICE_URL=http://localhost:3004
DELIVERY_SERVICE_URL=http://localhost:3006
# Also needs DEPOT_SERVICE_URL (defined above) for the franchise dashboard (M-R3.2).

# ---- API Gateway (single ingress, no database) ----
# Public entry point; routes /{service}/... to each upstream (strips the segment).
GATEWAY_PORT=8080
AUTH_SERVICE_URL=http://localhost:3001
CUSTOMER_SERVICE_URL=http://localhost:3002
PRODUCT_SERVICE_URL=http://localhost:3003
PAYMENT_SERVICE_URL=http://localhost:3005
DEPOT_SERVICE_URL=http://localhost:3007
DASHBOARD_SERVICE_URL=http://localhost:3008
LOYALTY_SERVICE_URL=http://localhost:3009
PROMO_SERVICE_URL=http://localhost:3010
REFERRAL_SERVICE_URL=http://localhost:3011
CRM_SERVICE_URL=http://localhost:3012
RECOMMENDATION_SERVICE_URL=http://localhost:3013
FORECAST_SERVICE_URL=http://localhost:3014
PAYOUT_SERVICE_URL=http://localhost:3016
# (ORDER_SERVICE_URL and DELIVERY_SERVICE_URL are defined above.)

# ---- Depot Service ----
DEPOT_SERVICE_PORT=3007
DEPOT_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_depot?schema=public
# Low-stock alerting (FR-074), optional. Both blank = disabled (no alert emitted).
# CRM_SERVICE_URL reuses crm-service; DEPOT_ALERT_PHONE is the ops/warehouse WhatsApp number.
CRM_SERVICE_URL=http://localhost:3012
DEPOT_ALERT_PHONE=

# ---- Loyalty Service ----
LOYALTY_SERVICE_PORT=3009
LOYALTY_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_loyalty?schema=public
# Loyalty policy (BR-013/BR-014): 1 point per this many rupiah of subtotal; expiry in months.
LOYALTY_EARN_RATE_RUPIAH=1000
LOYALTY_POINT_EXPIRY_MONTHS=12

# ---- Promo Service (vouchers/coupons) ----
PROMO_SERVICE_PORT=3010
PROMO_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_promo?schema=public

# ---- Referral Service (FR-092) ----
REFERRAL_SERVICE_PORT=3011
REFERRAL_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_referral?schema=public
# loyalty-service base URL — referral rewards are granted as loyalty points here.
LOYALTY_SERVICE_URL=http://localhost:3009
# Referral reward policy (company policy, not in PRD): points granted on qualification.
REFERRAL_REFERRER_POINTS=500
REFERRAL_REFEREE_POINTS=250

# ---- CRM Service (broadcast campaigns, FR-088/FR-094) ----
CRM_SERVICE_PORT=3012
CRM_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_crm?schema=public
# WhatsApp Business Cloud API for broadcasts. Blank in dev = console/log fallback (no send).
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
# customer-service base URL for FR-087 attribute segmentation. Blank disables segment targeting.
CUSTOMER_SERVICE_URL=http://localhost:3002
# Shared secret authenticating system-to-system notification calls (POST /notifications/internal).
# Must match INTERNAL_SERVICE_KEY in every service that sends internal notifications. Blank = fail-closed.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
INTERNAL_SERVICE_KEY=change-me-internal-service-key

# ---- Recommendation Service ----
RECOMMENDATION_SERVICE_PORT=3013
RECOMMENDATION_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_recommendation?schema=public
# order-service base URL; used later for the completed-orders rebuild feed (fail-open when blank).
ORDER_SERVICE_URL=http://localhost:3004

# ---- Forecast Service (demand forecasting / predictive analytics read model) ----
# FORECAST_SERVICE_URL for the gateway is defined in the API Gateway block above.
FORECAST_SERVICE_PORT=3014
FORECAST_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_forecast?schema=public

# ---- Payout Service ----
PAYOUT_SERVICE_PORT=3016
PAYOUT_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_payout?schema=public
PAYOUT_COMMISSION_RATE=0.05

# ---- Auth Service ----
AUTH_SERVICE_PORT=3001

# crm-service base URL + shared internal key for the registration welcome (fail-open; both blank = disabled).
CRM_SERVICE_URL=http://localhost:3012
INTERNAL_SERVICE_KEY=change-me-internal-service-key

# PostgreSQL connection string used by Prisma (auth-service).
# Local docker-compose default shown below.
AUTH_DATABASE_URL=postgresql://hydromart:hydromart@localhost:5432/hydromart_auth?schema=public

# JWT signing. Use long, random, high-entropy values in every environment.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# One-Time Password policy (BR-002: OTP valid max 5 minutes).
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# OTP delivery channel: console | whatsapp | sms
# 'console' logs the OTP (development only). whatsapp/sms require provider creds below.
OTP_DELIVERY_CHANNEL=console

# WhatsApp Business API (used when OTP_DELIVERY_CHANNEL=whatsapp)
WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_OTP_TEMPLATE=hydromart_otp

# SMS provider (used when OTP_DELIVERY_CHANNEL=sms)
SMS_API_BASE_URL=
SMS_API_TOKEN=
SMS_SENDER_ID=HYDROMART

# Google Sign-In (FR-006). Server verifies the ID token against this client id.
GOOGLE_OAUTH_CLIENT_ID=

# ---- Security ----
# Comma-separated list of allowed CORS origins for the customer web app.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Global API rate limit (requests per window) for public endpoints.
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=100

# ─── Object storage (uploads: PoD photo/signature + product images) ───
# BiznetGio NEO Object Storage (S3-compatible). Keys are PER-BUCKET, so delivery
# and product each get their own. Set STORAGE_DRIVER=local only for a throwaway
# dev box (files live in the container and vanish on redeploy).
STORAGE_DRIVER=s3
STORAGE_S3_ENDPOINT=https://nos.jkt-1.neo.id
STORAGE_S3_REGION=jkt-1
# delivery-service → bucket hydromart-pod
DELIVERY_STORAGE_S3_BUCKET=hydromart-pod
DELIVERY_STORAGE_S3_ACCESS_KEY_ID=
DELIVERY_STORAGE_S3_SECRET_ACCESS_KEY=
DELIVERY_STORAGE_PUBLIC_BASE_URL=https://nos.jkt-1.neo.id/hydromart-pod
# product-service → bucket hydromart-products
PRODUCT_STORAGE_S3_BUCKET=hydromart-products
PRODUCT_STORAGE_S3_ACCESS_KEY_ID=
PRODUCT_STORAGE_S3_SECRET_ACCESS_KEY=
PRODUCT_STORAGE_PUBLIC_BASE_URL=https://nos.jkt-1.neo.id/hydromart-products
